#!/bin/bash
# ============================================================
#  RHAFF SERVICE · WireGuard   (commande : menu-wg)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

WGCONF=/etc/wireguard/wg0.conf
DB=/etc/nvpanel/db/wireguard
NDIR=/etc/nvpanel/wg
SRV_IP=$(cat /etc/nvpanel/ip 2>/dev/null)
NET="10.66.66"
PORT=51820
mkdir -p /etc/nvpanel/db "$NDIR"
touch "$DB"

header(){ banner; center " 🛡️  WIREGUARD " "${BOLD}${WHT}"; line; proto_dash wireguard wg; line; }

install_wg() {
  header; printf "${CYN}➜${NC} Installation de WireGuard…\n"
  export DEBIAN_FRONTEND=noninteractive
  apt-get install -y wireguard qrencode >/dev/null 2>&1
  mkdir -p /etc/wireguard
  local spriv spub ifc
  spriv=$(wg genkey); spub=$(printf '%s' "$spriv" | wg pubkey)
  echo "$spub" > "$NDIR/server.pub"
  ifc=$(ip route | awk '/default/{print $5; exit}')
  cat > "$WGCONF" <<EOF
[Interface]
Address = $NET.1/24
ListenPort = $PORT
PrivateKey = $spriv
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o $ifc -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o $ifc -j MASQUERADE
EOF
  sed -i 's/^#\?net.ipv4.ip_forward.*/net.ipv4.ip_forward=1/' /etc/sysctl.conf
  grep -q '^net.ipv4.ip_forward=1' /etc/sysctl.conf || echo 'net.ipv4.ip_forward=1' >> /etc/sysctl.conf
  sysctl -p >/dev/null 2>&1
  systemctl enable --now wg-quick@wg0 >/dev/null 2>&1
  ok "WireGuard installé (port $PORT/udp)."; sleep 1
}

ensure_wg() {
  if ! command -v wg >/dev/null 2>&1 || [ ! -f "$WGCONF" ]; then
    ask " WireGuard n'est pas installé. L'installer ? (o/n) : " r
    confirm "$r" && install_wg || return 1
  fi
}

next_ip() {
  local last
  last=$(awk '{print $4}' "$DB" | awk -F. '{print $4}' | sort -n | tail -1)
  echo $(( ${last:-1} + 1 ))
}

add_peer() {
  header; ask " Nom du client : " name
  [ -z "$name" ] && { err "Nom vide"; pause; return; }
  grep -q "^### $name " "$DB" && { err "Existe déjà"; pause; return; }
  ask " Durée (jours) : " days; [[ "$days" =~ ^[0-9]+$ ]] || days=30
  local ppriv ppub ip exp spub
  ppriv=$(wg genkey); ppub=$(printf '%s' "$ppriv" | wg pubkey)
  ip="$NET.$(next_ip)"; exp=$(date -d "+$days days" +"%Y-%m-%d")
  spub=$(cat "$NDIR/server.pub")

  cat >> "$WGCONF" <<EOF

[Peer]
# $name
PublicKey = $ppub
AllowedIPs = $ip/32
EOF
  wg set wg0 peer "$ppub" allowed-ips "$ip/32" 2>/dev/null
  echo "### $name $ppub $ip $exp" >> "$DB"

  local conf="$NDIR/$name.conf"
  local _bn; _bn=$(head -1 /etc/banner 2>/dev/null | tr -d '\r\n')
  cat > "$conf" <<EOF
# ${_bn:-RHAFF SERVICE} - $name
[Interface]
PrivateKey = $ppriv
Address = $ip/32
DNS = 1.1.1.1

[Peer]
PublicKey = $spub
Endpoint = $SRV_IP:$PORT
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
EOF

  clear; header; ok "Client WireGuard créé (expire $exp)"
  echo
  printf "${GRY}--- Config client (copie-la dans un fichier .conf) ---${NC}\n"
  cat "$conf"
  echo
  command -v qrencode >/dev/null 2>&1 && { printf "${GRY}--- QR code ---${NC}\n"; qrencode -t ANSIUTF8 < "$conf"; }
  pause
}

list_peers() {
  header; printf " ${GRY}%-16s %-14s %s${NC}\n" "Nom" "IP" "Expire"; line
  awk '/^### /{printf " %-16s %-14s %s\n",$2,$4,$5}' "$DB"
  [ -s "$DB" ] || printf " ${GRY}(aucun client)${NC}\n"
  pause
}

pick_peer() {
  PICK=""
  mapfile -t _pl < <(awk '/^### /{print $2"|"$4"|"$5}' "$DB" 2>/dev/null)
  if [ "${#_pl[@]}" -eq 0 ]; then err "Aucun client WireGuard."; pause; return 1; fi
  echo; printf "   ${GRY}Clients WireGuard :${NC}\n"
  local i=1 row f
  for row in "${_pl[@]}"; do
    IFS='|' ask "" nm ip ex <<< "$row"
    printf "   ${WHT}%2d${NC}) %-16s ${GRY}%-14s exp %s${NC}\n" "$i" "$nm" "$ip" "$ex"; i=$((i+1))
  done
  echo; ask "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_pl[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_pl[$((n-1))]%%|*}"; return 0
}

del_peer() {
  header; pick_peer || return; name="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$name"; ask "" c; confirm "$c" || { pause; return; }
  local pub; pub=$(awk -v n="$name" '$2==n{print $3}' "$DB")
  wg set wg0 peer "$pub" remove 2>/dev/null
  sed -i "/^# $name$/,/^AllowedIPs/d" "$WGCONF"
  sed -i "/^### $name /d" "$DB"
  rm -f "$NDIR/$name.conf"
  ok "$name supprimé"; pause
}

renew_peer() {
  header; pick_peer || return; name="$PICK"
  ask " Ajouter (jours) : " days
  [[ "$days" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return; }
  local exp; exp=$(date -d "+$days days" +"%Y-%m-%d")
  sed -i "s|^### $name \([^ ]*\) \([^ ]*\) .*|### $name \1 \2 $exp|" "$DB"
  ok "$name prolongé jusqu'au $exp"; pause
}

ensure_wg || exit 0
view_peer() {
  header; pick_peer || return; name="$PICK"
  local conf="$NDIR/$name.conf"
  clear; header
  if [ -s "$conf" ]; then
    ok "Configuration de $name"
    echo; printf "${GRY}--- Config client (.conf) ---${NC}\n"
    printf "${WHT}"; cat "$conf"; printf "${NC}\n"
    command -v qrencode >/dev/null 2>&1 && { printf "\n${GRY}--- QR code ---${NC}\n"; qrencode -t ANSIUTF8 < "$conf"; }
  else
    err "Fichier de configuration introuvable pour $name."
  fi
  pause
}

cleanup_menu() {
  while true; do
    header; center " 🧹  NETTOYAGE WIREGUARD " "${BOLD}${WHT}"; line
    local tot exp today c r nm pub n
    today=$(date +%F)
    tot=$(grep -c '^### ' "$DB" 2>/dev/null); tot=${tot:-0}
    exp=$(awk -v d="$today" '/^### /{ if ($5!="" && $5<d) c++ } END{print c+0}' "$DB" 2>/dev/null)
    printf "   ${GRY}Clients au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les clients expirés"
    entry "2" "💥" "Supprimer TOUS les clients"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1|2)
        if [ "$c" = 1 ]; then
          [ "$exp" -eq 0 ] && { warn "Aucun client expiré."; pause; continue; }
          printf "   ${YLW}Supprimer les %s client(s) expiré(s) ? (o/n) : ${NC}" "$exp"; ask "" r
          confirm "$r" || continue
          list=$(awk -v d="$today" '/^### /{ if ($5!="" && $5<d) print $2 }' "$DB")
        else
          [ "$tot" -eq 0 ] && { warn "Aucun client."; pause; continue; }
          warn "Cela supprimera les $tot clients WireGuard. Action irréversible."
          printf "   ${RED}➤ Confirmer la suppression totale ? (o/n) : ${NC}"; ask "" r
          confirm "$r" || { warn "Annulé."; pause; continue; }
          list=$(awk '/^### /{print $2}' "$DB")
        fi
        n=0
        for nm in $list; do
          [ -z "$nm" ] && continue
          pub=$(awk -v x="$nm" '$2==x{print $3}' "$DB")
          [ -n "$pub" ] && wg set wg0 peer "$pub" remove 2>/dev/null
          sed -i "/^# $nm$/,/^AllowedIPs/d" "$WGCONF" 2>/dev/null
          sed -i "/^### $nm /d" "$DB" 2>/dev/null
          rm -f "$NDIR/$nm.conf"
          n=$((n+1))
        done
        ok "$n client(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

while true; do
  header
  entry "1" "➕" "Ajouter un client"
  entry "2" "📋" "Lister les clients"
  entry "3" "🔍" "Revoir un client (config + QR)"
  entry "4" "♻️" "Prolonger un client"
  entry "5" "🗑️" "Supprimer un client"
  entry "6" "🧹" "Nettoyage (expirés / tout supprimer)"
  entry "0" "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}➤ Choix :${NC} ")" o
  case "$o" in
    1) add_peer ;; 2) list_peers ;; 3) view_peer ;;
    4) renew_peer ;; 5) del_peer ;; 6) cleanup_menu ;;
    0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
