#!/bin/bash
# ============================================================
#  nvpanel · activation TLS/HTTPS   (commande : install-tls)
#  nginx (443) + certificat Let's Encrypt devant les entrées
#  WebSocket de Xray (vmess/vless/trojan).
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

DOMAIN=$(cat /etc/nvpanel/domain 2>/dev/null)
banner; center " ACTIVATION TLS / HTTPS " "${BOLD}${WHT}"; line

if [ -z "$DOMAIN" ]; then
  err "Aucun domaine défini. Configure-le d'abord (menu → Réglages, ou menu-settings)."
  pause; exit 1
fi
printf " Domaine : ${WHT}%s${NC}\n" "$DOMAIN"
printf " ${GRY}Assure-toi que %s pointe (enregistrement A) vers %s${NC}\n\n" "$DOMAIN" "$(cat /etc/nvpanel/ip 2>/dev/null)"
read -rp " Continuer ? (o/n) : " r; confirm "$r" || exit 0

# Dépendances
export DEBIAN_FRONTEND=noninteractive
apt-get install -y nginx certbot >/dev/null 2>&1

# Certificat (mode standalone : port 80 libre le temps de l'émission)
printf "${CYN}➜${NC} Obtention du certificat…\n"
systemctl stop nginx >/dev/null 2>&1
certbot certonly --standalone --non-interactive --agree-tos \
  -m "admin@$DOMAIN" -d "$DOMAIN" \
  --deploy-hook "systemctl reload nginx" >/dev/null 2>&1

CERT=/etc/letsencrypt/live/$DOMAIN
if [ ! -f "$CERT/fullchain.pem" ]; then
  err "Échec de l'émission du certificat. Vérifie que le domaine pointe bien vers ce VPS et que le port 80 est ouvert."
  systemctl start nginx >/dev/null 2>&1; pause; exit 1
fi

# Vhost nginx : bloc TLS 443 (le port sans TLS reste servi par rhaff-http.conf)
cat > /etc/nginx/conf.d/rhaff-tls.conf <<EOF
server {
    listen 443 ssl;
    server_name $DOMAIN;
    ssl_certificate     $CERT/fullchain.pem;
    ssl_certificate_key $CERT/privkey.pem;

    location /vmess  { proxy_pass http://127.0.0.1:8080; include /etc/nginx/nvpanel-ws.conf; }
    location /vless  { proxy_pass http://127.0.0.1:8081; include /etc/nginx/nvpanel-ws.conf; }
    location /trojan { proxy_pass http://127.0.0.1:8082; include /etc/nginx/nvpanel-ws.conf; }
    location / { return 200 "ok"; }
}
EOF

cat > /etc/nginx/nvpanel-ws.conf <<'EOF'
proxy_http_version 1.1;
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection "upgrade";
proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_read_timeout 300s;
EOF

# Retire le site par défaut s'il capte le 443
rm -f /etc/nginx/sites-enabled/default 2>/dev/null

if nginx -t >/dev/null 2>&1; then
  systemctl enable nginx >/dev/null 2>&1
  systemctl restart nginx
  touch /etc/nvpanel/tls_on
  clear; banner; center " TLS ACTIF " "${BOLD}${GRN}"; line
  ok "HTTPS activé sur $DOMAIN (port 443)."
  printf "   ${GRY}Les nouveaux liens Vmess/Vless/Trojan utiliseront TLS + port 443.${NC}\n"
  printf "   ${GRY}Renouvellement du certificat : automatique (certbot).${NC}\n"
else
  err "Configuration nginx invalide. TLS non activé."
  rm -f /etc/nvpanel/tls_on
fi
pause
