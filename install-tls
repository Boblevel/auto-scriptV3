#!/bin/bash
# ============================================================
#  RHAFF SERVICE · activation TLS/HTTPS   (install-tls)
#  Obtient un certificat Let's Encrypt SANS couper nginx.
#  En cas d'échec, rien n'est cassé : le certificat auto-signé
#  reste en place et les comptes Vmess/Vless/Trojan continuent.
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

DOMAIN=$(cat /etc/nvpanel/domain 2>/dev/null)
IP=$(cat /etc/nvpanel/ip 2>/dev/null)
banner; center " ACTIVATION TLS / HTTPS " "${BOLD}${WHT}"; line
[ -z "$DOMAIN" ] && { err "Aucun domaine défini (menu-settings → option 1)."; pause; exit 1; }

printf " Domaine : ${WHT}%s${NC}\n" "$DOMAIN"
printf " ${GRY}%s doit pointer (enregistrement A) vers %s, sans proxy Cloudflare.${NC}\n" "$DOMAIN" "$IP"
printf " ${GRY}Si le certificat échoue, tes comptes continueront de fonctionner.${NC}\n\n"
read -rp " Continuer ? (o/n) : " r; confirm "$r" || exit 0

export DEBIAN_FRONTEND=noninteractive
printf "${CYN}➜${NC} Préparation…\n"
apt-get install -y certbot >/dev/null 2>&1
mkdir -p /var/www/certbot

# nginx doit tourner (il sert le challenge sur le port 80) — AUCUNE coupure
[ -x /usr/local/bin/install-xray ] && command -v xray >/dev/null 2>&1 || true
nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1 || systemctl start nginx >/dev/null 2>&1

printf "${CYN}➜${NC} Obtention du certificat Let's Encrypt…\n"
certbot certonly --webroot -w /var/www/certbot --non-interactive --agree-tos \
  -m "admin@$DOMAIN" -d "$DOMAIN" >/dev/null 2>&1

CERT=/etc/letsencrypt/live/$DOMAIN
if [ -f "$CERT/fullchain.pem" ]; then
  touch /etc/nvpanel/tls_on
  # régénère la façade nginx : install-xray détecte le certificat officiel
  [ -x /usr/local/bin/install-xray ] && /usr/local/bin/install-xray auto >/dev/null 2>&1
  nginx -t >/dev/null 2>&1 && { systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx >/dev/null 2>&1; }
  clear; banner; center " ✔  TLS ACTIF " "${BOLD}${GRN}"; line
  ok "HTTPS activé sur $DOMAIN (certificat officiel Let's Encrypt)."
  printf "   ${GRY}Tes comptes Vmess/Vless/Trojan continuent de marcher — désormais avec un vrai certificat.${NC}\n"
  printf "   ${GRY}Renouvellement automatique.${NC}\n"
else
  # Échec : on ne casse RIEN. L'auto-signé reste, les comptes marchent toujours.
  nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
  clear; banner; center " TLS NON ACTIVÉ " "${BOLD}${YLW}"; line
  warn "Certificat Let's Encrypt non obtenu (DNS pas prêt, port 80 bloqué, ou proxy Cloudflare)."
  printf "   ${GRN}Aucune inquiétude :${NC} ${GRY}tes comptes fonctionnent toujours (certificat auto-signé).${NC}\n"
  printf "   ${GRY}Vérifie que %s pointe vers %s (DNS only), puis réessaie.${NC}\n" "$DOMAIN" "$IP"
fi
pause
