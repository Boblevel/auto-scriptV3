#!/bin/bash
# ============================================================
#  nvpanel · gestion Shadowsocks   (menu-ss)
#  Interface — logique dans nvpanel-cli (proto = ss)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT INT TERM HUP
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

header(){ banner; center " GESTION SHADOWSOCKS " "${BOLD}${WHT}"; line; proto_dash shadowsocks port:8388; line; }

ensure_xray() {
  if [ ! -f /usr/local/etc/xray/config.json ] || ! command -v xray >/dev/null 2>&1; then
    warn "Xray n'est pas installé."
    ask " L'installer maintenant ? (o/n) : " r
    confirm "$r" && install-xray || return 1
  fi
}

add_client() {
  local name days out
  if [ -n "$1" ]; then
    name="$1"; days="${2:-1}"
  else
  header; ask " Nom du client : " name
  [ -z "$name" ] && { err "Nom vide"; pause; return; }
  ask " Durée (jours) : " days
  fi
  out=$(nvpanel-cli xadd ss "$name" "$days")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Client Shadowsocks créé"
    echo; printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else err "Échec : $(echo "$out"|head -1)"; fi
  pause
}
list_clients() {
  header; printf " ${GRY}%-20s %s${NC}\n" "Nom" "Expire"; line
  nvpanel-cli xlist ss | while IFS='|' ask "" n e; do printf " %-20s %s\n" "$n" "$e"; done
  pause
}

_rand_name(){ printf 'test%s' "$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c4)"; }
_rand_pass(){ tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c8; }

trial_client() {
  banner; center " 🎁  COMPTE TEST 24 H " "${BOLD}${WHT}"; line
  printf "   ${GRY}Génération d'un client Shadowsocks valable 24 heures…${NC}\n"
  add_client "$(_rand_name)" 1
}

pick_client() {
  PICK=""
  mapfile -t _cl < <(nvpanel-cli xlist ss | awk -F'|' 'NF{print $1"|"$2}')
  if [ "${#_cl[@]}" -eq 0 ]; then err "Aucun client Shadowsocks."; pause; return 1; fi
  echo; printf "   ${GRY}Clients Shadowsocks :${NC}\n"
  local i=1 row
  for row in "${_cl[@]}"; do
    printf "   ${WHT}%2d${NC}) %-18s ${GRY}exp %s${NC}\n" "$i" "${row%%|*}" "${row##*|}"; i=$((i+1))
  done
  echo; ask "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_cl[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_cl[$((n-1))]%%|*}"; return 0
}
del_client() {
  header; pick_client || return; name="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$name"; ask "" c; confirm "$c" || { pause; return; }
  r=$(nvpanel-cli xdel ss "$name"); echo "$r"|grep -q '^OK' && ok "$name supprimé" || err "$r"; pause
}
renew_client() {
  header; pick_client || return; name="$PICK"; ask " Ajouter (jours) : " days
  r=$(nvpanel-cli xrenew ss "$name" "$days")
  echo "$r"|grep -q '^OK' && ok "Prolongé" || err "$r"; pause
}
view_client() {
  header; pick_client || return; name="$PICK"
  out=$(nvpanel-cli xinfo ss "$name")
  clear; header
  if echo "$out"|head -1|grep -q '^OK'; then printf "${GRN}"; echo "$out"|tail -n +2; printf "${NC}"; else err "Introuvable : $out"; fi
  pause
}

cleanup_menu() {
  while true; do
    banner; center " 🧹  NETTOYAGE SHADOWSOCKS " "${BOLD}${WHT}"; line
    local tot exp today c r out
    today=$(date +%F)
    tot=$(nvpanel-cli xlist ss 2>/dev/null | grep -c '|')
    exp=$(nvpanel-cli xlist ss 2>/dev/null | awk -F'|' -v d="$today" 'NF && $2!="" && $2<d {c++} END{print c+0}')
    printf "   ${GRY}Clients au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les clients expirés"
    entry "2" "💥" "Supprimer TOUS les clients"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) [ "$exp" -eq 0 ] && { warn "Aucun client expiré."; pause; continue; }
         printf "   ${YLW}Supprimer les %s client(s) expiré(s) ? (o/n) : ${NC}" "$exp"; ask "" r
         confirm "$r" || continue
         out=$(nvpanel-cli purge ss expired)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      2) [ "$tot" -eq 0 ] && { warn "Aucun client."; pause; continue; }
         warn "Cela supprimera les $tot clients Shadowsocks. Action irréversible."
         printf "   ${RED}➤ Confirmer la suppression totale ? (o/n) : ${NC}"; ask "" r
         confirm "$r" || { warn "Annulé."; pause; continue; }
         out=$(nvpanel-cli purge ss all)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

uninstall_xray(){
  banner; center " 🗑️  DÉSINSTALLER XRAY " "${BOLD}${RED}"; line
  warn "ATTENTION : le cœur Xray gère 4 protocoles à la fois."
  printf "   ${YLW}Vmess · Vless · Trojan · Shadowsocks seront TOUS supprimés,${NC}\n"
  printf "   ${YLW}avec l'ensemble de leurs clients.${NC}\n"
  printf "   ${GRY}SSH, SlowDNS, UDP, WireGuard, L2TP, PPTP et SSTP ne sont pas touchés.${NC}\n\n"
  printf "   ${RED}➤ Confirmer la désinstallation ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }

  printf "\n${CYN}➜${NC} Arrêt et retrait de Xray…\n"
  systemctl disable --now xray >/dev/null 2>&1
  bash <(curl -sL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) remove --purge >/dev/null 2>&1
  rm -rf /usr/local/etc/xray /etc/nvpanel/xray

  printf "${CYN}➜${NC} Suppression des clients…\n"
  rm -f /etc/nvpanel/db/vmess /etc/nvpanel/db/vless /etc/nvpanel/db/trojan /etc/nvpanel/db/shadowsocks

  printf "${CYN}➜${NC} Retrait de la façade web…\n"
  rm -f /etc/nginx/conf.d/rhaff.conf /etc/nginx/nvpanel-ws.conf
  nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1
  ok "Xray a été désinstallé (Vmess, Vless, Trojan, Shadowsocks)."
  pause
}

setup_menu(){
  while true; do
    banner; center " ⚙️  INSTALLER / DÉSINSTALLER XRAY " "${BOLD}${WHT}"; line
    if systemctl is-active --quiet xray 2>/dev/null; then
      printf "   ${GRY}État actuel :${NC} ${GRN}installé et actif${NC}\n"
    else
      printf "   ${GRY}État actuel :${NC} ${RED}non installé${NC}\n"
    fi
    printf "   ${GRY}Concerne Vmess · Vless · Trojan · Shadowsocks${NC}\n\n"
    entry "1" "⬇️" "Installer / réinstaller"
    entry "2" "🗑️" "Désinstaller"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) install-xray ;;
      2) uninstall_xray ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

ensure_xray || exit 0
while true; do
  header
  entry "1" "➕" "Ajouter un client"; entry "2" "📋" "Lister les clients"
  entry "3" "🔍" "Revoir un client"; entry "4" "♻️" "Prolonger un client"
  entry "5" "🗑️" "Supprimer un client"; entry "6" "🧹" "Nettoyage des comptes"
  entry "7" "🎁" "Compte test 24 h"
  entry "8" "⚙️" "Installer / désinstaller"
  entry "0" "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}Choix :${NC} ")" o || break
  case "$o" in 1) add_client ;; 2) list_clients ;; 3) view_client ;; 4) renew_client ;; 5) del_client ;; 6) cleanup_menu ;; 7) trial_client ;; 8) setup_menu ;; 0) break ;; *) warn "Invalide"; sleep 1 ;; esac
done
