#!/bin/bash
# ============================================================
#  nvpanel · gestion Shadowsocks   (menu-ss)
#  Interface — logique dans nvpanel-cli (proto = ss)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

header(){ banner; center " GESTION SHADOWSOCKS " "${BOLD}${WHT}"; line; proto_dash shadowsocks port:8388; line; }

ensure_xray() {
  if [ ! -f /usr/local/etc/xray/config.json ] || ! command -v xray >/dev/null 2>&1; then
    warn "Xray n'est pas installé."
    read -rp " L'installer maintenant ? (o/n) : " r
    confirm "$r" && install-xray || return 1
  fi
}

add_client() {
  header; read -rp " Nom du client : " name
  [ -z "$name" ] && { err "Nom vide"; pause; return; }
  read -rp " Durée (jours) : " days
  out=$(nvpanel-cli xadd ss "$name" "$days")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Client Shadowsocks créé"
    echo; printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else err "Échec : $(echo "$out"|head -1)"; fi
  pause
}
list_clients() {
  header; printf " ${GRY}%-20s %s${NC}\n" "Nom" "Expire"; line
  nvpanel-cli xlist ss | while IFS='|' read -r n e; do printf " %-20s %s\n" "$n" "$e"; done
  pause
}
pick_client() {
  PICK=""
  mapfile -t _cl < <(nvpanel-cli xlist ss | awk -F'|' 'NF{print $1"|"$2}')
  if [ "${#_cl[@]}" -eq 0 ]; then err "Aucun client Shadowsocks."; pause; return 1; fi
  echo; printf "   ${GRY}Clients Shadowsocks :${NC}\n"
  local i=1 row
  for row in "${_cl[@]}"; do
    printf "   ${WHT}%2d${NC}) %-18s ${GRY}exp %s${NC}\n" "$i" "${row%%|*}" "${row##*|}"; i=$((i+1))
  done
  echo; read -rp "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_cl[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_cl[$((n-1))]%%|*}"; return 0
}
del_client() {
  header; pick_client || return; name="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$name"; read -r c; confirm "$c" || { pause; return; }
  r=$(nvpanel-cli xdel ss "$name"); echo "$r"|grep -q '^OK' && ok "$name supprimé" || err "$r"; pause
}
renew_client() {
  header; pick_client || return; name="$PICK"; read -rp " Ajouter (jours) : " days
  r=$(nvpanel-cli xrenew ss "$name" "$days")
  echo "$r"|grep -q '^OK' && ok "Prolongé" || err "$r"; pause
}
view_client() {
  header; pick_client || return; name="$PICK"
  out=$(nvpanel-cli xinfo ss "$name")
  clear; header
  if echo "$out"|head -1|grep -q '^OK'; then printf "${GRN}"; echo "$out"|tail -n +2; printf "${NC}"; else err "Introuvable : $out"; fi
  pause
}

cleanup_menu() {
  while true; do
    header; center " 🧹  NETTOYAGE SHADOWSOCKS " "${BOLD}${WHT}"; line
    local tot exp today c r out
    today=$(date +%F)
    tot=$(nvpanel-cli xlist ss 2>/dev/null | grep -c '|')
    exp=$(nvpanel-cli xlist ss 2>/dev/null | awk -F'|' -v d="$today" 'NF && $2!="" && $2<d {c++} END{print c+0}')
    printf "   ${GRY}Clients au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les clients expirés"
    entry "2" "💥" "Supprimer TOUS les clients"
    entry "0" "⬅️" "Retour"
    line
    read -rp "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) [ "$exp" -eq 0 ] && { warn "Aucun client expiré."; pause; continue; }
         printf "   ${YLW}Supprimer les %s client(s) expiré(s) ? (o/n) : ${NC}" "$exp"; read -r r
         confirm "$r" || continue
         out=$(nvpanel-cli purge ss expired)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      2) [ "$tot" -eq 0 ] && { warn "Aucun client."; pause; continue; }
         warn "Cela supprimera les $tot clients Shadowsocks. Action irréversible."
         printf "   ${RED}Tape SUPPRIMER (en majuscules) pour confirmer : ${NC}"; read -r r
         [ "$r" = "SUPPRIMER" ] || { warn "Annulé."; pause; continue; }
         out=$(nvpanel-cli purge ss all)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

ensure_xray || exit 0
while true; do
  header
  entry "1" "➕" "Ajouter un client"; entry "2" "📋" "Lister les clients"
  entry "3" "🔍" "Revoir un client"; entry "4" "♻️" "Prolonger un client"
  entry "5" "🗑️" "Supprimer un client"; entry "6" "🧹" "Nettoyage (expirés / tout)"
  entry "0" "⬅️" "Retour"
  line
  read -rp "$(printf " ${WHT}Choix :${NC} ")" o
  case "$o" in 1) add_client ;; 2) list_clients ;; 3) view_client ;; 4) renew_client ;; 5) del_client ;; 6) cleanup_menu ;; 0) break ;; *) warn "Invalide"; sleep 1 ;; esac
done
