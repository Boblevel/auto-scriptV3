#!/bin/bash
# ============================================================
#  RHAFF SERVICE · gestion L2TP / PPTP / SSTP
#  Usage : menu-ppp l2tp|pptp|sstp
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT INT TERM HUP
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

PROTO="$1"
case "$PROTO" in
  l2tp) LABEL="L2TP"; INST=install-l2tp; SVC="xl2tpd" ;;
  pptp) LABEL="PPTP";         INST=install-pptp; SVC="pptpd" ;;
  sstp) LABEL="SSTP";         INST=install-sstp; SVC="nvpanel-sstp" ;;
  *) err "Protocole inconnu"; exit 1 ;;
esac
DB=/etc/nvpanel/db/$PROTO
mkdir -p /etc/nvpanel/db; touch "$DB"

dash(){
  proto_dash "$PROTO" "ppp:$PROTO"
  if systemctl is-active --quiet "$SVC" 2>/dev/null; then
    printf " ${GRY}⚙️  Service :${NC} ${GRN}actif${NC}\n"
  else
    printf " ${GRY}⚙️  Service :${NC} ${RED}arrêté / non installé${NC}\n"
  fi
}
header(){ banner; center " 🔐  $LABEL " "${BOLD}${WHT}"; line; dash; line; }

ensure(){
  systemctl is-active --quiet "$SVC" 2>/dev/null && return 0
  header
  warn "$LABEL n'est pas encore installé sur ce serveur."
  printf "   ${YLW}L'installer maintenant ? (o/n) : ${NC}"; ask "" r
  confirm "$r" && { "$INST"; return 1; }
  return 1
}


_rand_name(){ printf 'test%s' "$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c4)"; }
_rand_pass(){ tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c8; }

trial(){
  banner; center " 🎁  COMPTE TEST 24 H " "${BOLD}${WHT}"; line
  printf "   ${GRY}Génération d'un compte $LABEL valable 24 heures…${NC}\n"
  create "$(_rand_name)" "$(_rand_pass)" 1
}

pick(){
  PICK=""
  mapfile -t _l < <(awk '/^### /{print $2"|"$4}' "$DB" 2>/dev/null)
  [ "${#_l[@]}" -eq 0 ] && { err "Aucun compte."; pause; return 1; }
  echo; printf "   ${GRY}Comptes $LABEL :${NC}\n"
  local i=1 row
  for row in "${_l[@]}"; do
    printf "   ${WHT}%2d${NC}) %-18s ${GRY}exp %s${NC}\n" "$i" "${row%%|*}" "${row##*|}"; i=$((i+1))
  done
  echo; ask "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_l[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_l[$((n-1))]%%|*}"; return 0
}

create(){
  local u p d out
  if [ -n "$1" ]; then
    u="$1"; p="$2"; d="${3:-1}"
  else
  header; ask " Nom d'utilisateur : " u
  [ -z "$u" ] && { err "Nom vide"; pause; return; }
  ask " Mot de passe : " p
  [ -z "$p" ] && { err "Mot de passe vide"; pause; return; }
  ask " Durée (jours) : " d; [[ "$d" =~ ^[0-9]+$ ]] || d=30
  fi
  out=$(nvpanel-ppp add "$PROTO" "$u" "$p" "$d")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else
    case "$out" in *exists*) err "Ce nom existe déjà." ;; *) err "Échec : $out" ;; esac
  fi
  pause
}

list_all(){
  header
  printf " ${WHT}%-20s %s${NC}\n" "COMPTE" "EXPIRE"
  nvpanel-ppp list "$PROTO" | while IFS='|' read -r n e; do printf " %-20s %s\n" "$n" "$e"; done
  pause
}

view(){
  header; pick || return
  out=$(nvpanel-ppp info "$PROTO" "$PICK")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else err "Introuvable"; fi
  pause
}

renew(){
  header; pick || return
  ask " Ajouter (jours) : " d
  out=$(nvpanel-ppp renew "$PROTO" "$PICK" "$d")
  echo "$out" | grep -q '^OK' && ok "Prolongé jusqu'au $(echo "$out"|awk '{print $3}')" || err "Échec"
  pause
}

del(){
  header; pick || return
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$PICK"; ask "" c
  confirm "$c" || { pause; return; }
  out=$(nvpanel-ppp del "$PROTO" "$PICK")
  echo "$out" | grep -q '^OK' && ok "$PICK supprimé" || err "Échec"
  pause
}

cleanup_menu(){
  while true; do
    banner; center " 🧹  NETTOYAGE $LABEL " "${BOLD}${WHT}"; line
    local tot exp today c r out
    today=$(date +%F)
    tot=$(grep -c '^### ' "$DB" 2>/dev/null); tot=${tot:-0}
    exp=$(awk -v d="$today" '/^### /{ if ($4!="" && $4<d) c++ } END{print c+0}' "$DB" 2>/dev/null)
    printf "   ${GRY}Comptes au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les comptes expirés"
    entry "2" "💥" "Supprimer TOUS les comptes"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) [ "$exp" -eq 0 ] && { warn "Aucun compte expiré."; pause; continue; }
         printf "   ${YLW}Supprimer les %s compte(s) expiré(s) ? (o/n) : ${NC}" "$exp"; ask "" r
         confirm "$r" || continue
         out=$(nvpanel-ppp purge "$PROTO" expired)
         ok "$(echo "$out"|awk '{print $2+0}') compte(s) supprimé(s)."; pause ;;
      2) [ "$tot" -eq 0 ] && { warn "Aucun compte."; pause; continue; }
         warn "Cela supprimera les $tot comptes $LABEL. Action irréversible."
         printf "   ${RED}➤ Confirmer la suppression totale ? (o/n) : ${NC}"; ask "" r
         confirm "$r" || { warn "Annulé."; pause; continue; }
         out=$(nvpanel-ppp purge "$PROTO" all)
         ok "$(echo "$out"|awk '{print $2+0}') compte(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

uninstall_proto(){
  banner; center " 🗑️  DÉSINSTALLER $LABEL " "${BOLD}${RED}"; line
  warn "Cela supprime le service $LABEL et TOUS ses comptes."
  printf "   ${GRY}Les autres protocoles ne sont pas touchés.${NC}\n\n"
  printf "   ${RED}➤ Confirmer la désinstallation ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }

  printf "\n${CYN}➜${NC} Suppression des comptes…\n"
  nvpanel-ppp purge "$PROTO" all >/dev/null 2>&1
  rm -f "/etc/nvpanel/db/$PROTO"

  printf "${CYN}➜${NC} Arrêt et retrait du service…\n"
  export DEBIAN_FRONTEND=noninteractive
  case "$PROTO" in
    l2tp)
      for u in xl2tpd strongswan-starter strongswan ipsec; do systemctl disable --now "$u" >/dev/null 2>&1; done
      apt-get purge -y xl2tpd strongswan >/dev/null 2>&1
      apt-get autoremove -y >/dev/null 2>&1
      rm -f /etc/xl2tpd/xl2tpd.conf /etc/ppp/options.xl2tpd /etc/ipsec.conf /etc/ipsec.secrets /etc/nvpanel/l2tp_psk
      for p in 500 4500 1701; do iptables -D INPUT -p udp --dport $p -j ACCEPT 2>/dev/null; done
      iptables -t nat -D POSTROUTING -s 10.10.10.0/24 -o "$(ip route 2>/dev/null | awk '/default/{print $5; exit}')" -j MASQUERADE 2>/dev/null
      iptables -D FORWARD -s 10.10.10.0/24 -j ACCEPT 2>/dev/null
      iptables -D FORWARD -d 10.10.10.0/24 -j ACCEPT 2>/dev/null ;;
    pptp)
      systemctl disable --now pptpd >/dev/null 2>&1
      apt-get purge -y pptpd >/dev/null 2>&1
      apt-get autoremove -y >/dev/null 2>&1
      rm -f /etc/pptpd.conf /etc/ppp/pptpd-options
      iptables -D INPUT -p tcp --dport 1723 -j ACCEPT 2>/dev/null
      iptables -D INPUT -p gre -j ACCEPT 2>/dev/null
      iptables -t nat -D POSTROUTING -s 10.20.20.0/24 -o "$(ip route 2>/dev/null | awk '/default/{print $5; exit}')" -j MASQUERADE 2>/dev/null
      iptables -D FORWARD -s 10.20.20.0/24 -j ACCEPT 2>/dev/null
      iptables -D FORWARD -d 10.20.20.0/24 -j ACCEPT 2>/dev/null ;;
    sstp)
      systemctl disable --now nvpanel-sstp >/dev/null 2>&1
      rm -f /etc/systemd/system/nvpanel-sstp.service /etc/ppp/options.sstpd
      local sp; sp=$(cat /etc/nvpanel/sstp_port 2>/dev/null)
      [ -n "$sp" ] && iptables -D INPUT -p tcp --dport "$sp" -j ACCEPT 2>/dev/null
      rm -rf /etc/nvpanel/sstp /etc/nvpanel/sstp_port
      iptables -t nat -D POSTROUTING -s 10.30.30.0/24 -o "$(ip route 2>/dev/null | awk '/default/{print $5; exit}')" -j MASQUERADE 2>/dev/null
      iptables -D FORWARD -s 10.30.30.0/24 -j ACCEPT 2>/dev/null
      iptables -D FORWARD -d 10.30.30.0/24 -j ACCEPT 2>/dev/null ;;
  esac
  systemctl daemon-reload >/dev/null 2>&1
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1
  ok "$LABEL a été désinstallé."
  pause
}

setup_menu(){
  while true; do
    banner; center " ⚙️  INSTALLER / DÉSINSTALLER $LABEL " "${BOLD}${WHT}"; line
    if systemctl is-active --quiet "$SVC" 2>/dev/null; then
      printf "   ${GRY}État actuel :${NC} ${GRN}installé et actif${NC}\n\n"
    else
      printf "   ${GRY}État actuel :${NC} ${RED}non installé${NC}\n\n"
    fi
    entry "1" "⬇️" "Installer / réinstaller"
    entry "2" "🗑️" "Désinstaller"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) "$INST" ;;
      2) uninstall_proto ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

ensure || true
while true; do
  header
  entry "1" "➕" "Créer un compte"
  entry "2" "📋" "Lister les comptes"
  entry "3" "🔍" "Revoir un compte"
  entry "4" "♻️" "Prolonger un compte"
  entry "5" "🗑️" "Supprimer un compte"
  entry "6" "🧹" "Nettoyage des comptes"
  entry "7" "🎁" "Compte test 24 h"
  entry "8" "⚙️" "Installer / désinstaller"
  entry "0" "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}➤ Choix :${NC} ")" o
  case "$o" in
    1) create ;; 2) list_all ;; 3) view ;; 4) renew ;; 5) del ;;
    6) cleanup_menu ;; 7) trial ;; 8) setup_menu ;; 0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
