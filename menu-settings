#!/bin/bash
# ============================================================
#  RHAFF SERVICE · Paramètres système   (commande : menu-settings)
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
BKDIR=/root

header(){ banner; center " ⚙️  PARAMÈTRES SYSTÈME " "${BOLD}${WHT}"; line; }

set_domain(){
  header; read -rp " Domaine (ex. vpn.mondomaine.com) : " d
  [ -n "$d" ] && { echo "$d" > /etc/nvpanel/domain; ok "Domaine : $d"; } || warn "Inchangé"; pause
}
change_port(){
  header; printf " ${GRY}Port Dropbear actuel :${NC} %s\n" "$(grep -oP 'DROPBEAR_PORT=\K[0-9]+' /etc/default/dropbear 2>/dev/null || echo '?')"
  read -rp " Nouveau port Dropbear : " p
  [[ "$p" =~ ^[0-9]+$ ]] || { err "Port invalide"; pause; return; }
  if grep -q DROPBEAR_PORT /etc/default/dropbear 2>/dev/null; then
    sed -i "s/^DROPBEAR_PORT=.*/DROPBEAR_PORT=$p/" /etc/default/dropbear
  else echo "DROPBEAR_PORT=$p" >> /etc/default/dropbear; fi
  systemctl restart dropbear 2>/dev/null; ok "Port Dropbear : $p"; pause
}
backup_now(){
  header; local f="$BKDIR/rhaff-backup-$(date +%F-%H%M).tar.gz"
  tar czf "$f" /etc/nvpanel /usr/local/etc/xray /etc/wireguard 2>/dev/null
  ok "Sauvegarde créée : $f"; pause
}
autobackup(){
  header
  ( crontab -l 2>/dev/null | grep -v rhaff-backup; echo "0 4 * * * tar czf $BKDIR/rhaff-backup-auto.tar.gz /etc/nvpanel /usr/local/etc/xray /etc/wireguard 2>/dev/null" ) | crontab -
  ok "Sauvegarde automatique activée (tous les jours à 4h)."; pause
}
restore_data(){
  header; local files=("$BKDIR"/rhaff-backup-*.tar.gz)
  [ -e "${files[0]}" ] || { err "Aucune sauvegarde trouvée"; pause; return; }
  local i=1; for f in "${files[@]}"; do printf "  ${GRN}%s)${NC} %s\n" "$i" "$(basename "$f")"; i=$((i+1)); done
  read -rp " Numéro à restaurer : " n
  local sel="${files[$((n-1))]}"
  [ -f "$sel" ] || { err "Choix invalide"; pause; return; }
  tar xzf "$sel" -C / && ok "Restauré depuis $(basename "$sel")"; pause
}
ram_usage(){ header; free -h; echo; command -v vnstat >/dev/null && vnstat --oneline 2>/dev/null; pause; }
swap_ram(){
  header; read -rp " Taille du swap en Mo (ex. 1024) : " s
  [[ "$s" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return; }
  fallocate -l "${s}M" /swapfile 2>/dev/null || dd if=/dev/zero of=/swapfile bs=1M count="$s" 2>/dev/null
  chmod 600 /swapfile; mkswap /swapfile >/dev/null 2>&1; swapon /swapfile 2>/dev/null
  grep -q '/swapfile' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
  ok "Swap de ${s} Mo activé."; pause
}
enable_bbr(){
  header
  grep -q 'net.core.default_qdisc=fq' /etc/sysctl.conf || echo 'net.core.default_qdisc=fq' >> /etc/sysctl.conf
  grep -q 'tcp_congestion_control=bbr' /etc/sysctl.conf || echo 'net.ipv4.tcp_congestion_control=bbr' >> /etc/sysctl.conf
  sysctl -p >/dev/null 2>&1
  local cc; cc=$(sysctl -n net.ipv4.tcp_congestion_control)
  [ "$cc" = "bbr" ] && ok "BBR activé." || warn "BBR demandé (contrôle : $cc). Un redémarrage peut être nécessaire."
  pause
}
speedtest(){
  header; center " 📶  VITESSE DU SERVEUR " "${BOLD}${WHT}"; echo
  printf "   ${GRY}Mesure du débit descendant en cours…${NC}\n\n"
  local tmp; tmp=$(mktemp)
  ( curl -o /dev/null -s --max-time 30 -w '%{speed_download}' \
      "https://speed.cloudflare.com/__down?bytes=50000000" > "$tmp" 2>/dev/null ) &
  local pid=$! i=0 spin='|/-\'
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r   ${MAG}%s${NC}  téléchargement du test…   " "${spin:i++%4:1}"
    sleep 0.15
  done
  wait "$pid" 2>/dev/null
  local sp; sp=$(cat "$tmp" 2>/dev/null); rm -f "$tmp"
  printf "\r%-45s\r" " "
  if [ -n "$sp" ] && awk -v b="$sp" 'BEGIN{exit !(b>0)}'; then
    local mbps; mbps=$(awk -v b="$sp" 'BEGIN{printf "%.1f", b*8/1000000}')
    ok "Débit descendant : ${GRN}${mbps} Mbps${NC}"
  else
    printf "   ${CYN}➜${NC} Nouvel essai (autre source)…\n"
    local t0 t1 bytes
    t0=$(date +%s.%N)
    bytes=$(curl -o /dev/null -s --max-time 25 -w '%{size_download}' "http://speedtest.tele2.net/50MB.zip" 2>/dev/null)
    t1=$(date +%s.%N)
    if [ -n "$bytes" ] && awk -v b="$bytes" 'BEGIN{exit !(b>0)}'; then
      local mbps; mbps=$(awk -v b="$bytes" -v s="$t0" -v e="$t1" 'BEGIN{d=e-s; if(d<=0)d=1; printf "%.1f",(b*8)/(d*1000000)}')
      ok "Débit descendant : ${GRN}${mbps} Mbps${NC}"
    else
      err "Test impossible — le réseau du serveur bloque peut-être les téléchargements."
    fi
  fi
  pause
}
restart_services(){
  header; printf "${CYN}➜${NC} Redémarrage des services…\n"
  for s in ssh dropbear xray nginx wg-quick@wg0 nvpanel-slowdns nvpanel-limit nvpanel-bot; do
    systemctl restart "$s" >/dev/null 2>&1 && printf "  ${GRN}✔${NC} %s\n" "$s"
  done
  pause
}
renew_cert(){
  header; printf "${CYN}➜${NC} Renouvellement des certificats…\n"
  certbot renew --quiet 2>/dev/null && systemctl reload nginx 2>/dev/null
  ok "Renouvellement terminé (voir certbot pour le détail)."; pause
}
change_banner(){
  header
  printf "   ${WHT}Bannière SSH${NC} (s'affiche à la connexion au serveur)\n"
  printf "   ${GRY}Actuelle :${NC} %s\n\n" "$([ -s /etc/banner ] && head -1 /etc/banner || echo 'aucune')"
  entry "1" "➕" "Ajouter / modifier la bannière"
  entry "2" "🗑️" "Supprimer la bannière"
  entry "0" "⬅️" "Retour"
  line; read -rp "$(printf " ${WHT}➤ Choix :${NC} ")" b
  case "$b" in
    1)
      echo; printf "   ${GRY}Saisis ton texte (une ligne). Entrée pour valider.${NC}\n"
      read -rp "   Texte : " txt
      [ -z "$txt" ] && { warn "Inchangé"; pause; return; }
      printf '%s\n' "$txt" > /etc/banner
      # --- OpenSSH ---
      sed -i '/^[#[:space:]]*Banner[[:space:]]/d' /etc/ssh/sshd_config
      echo 'Banner /etc/banner' >> /etc/ssh/sshd_config
      systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null
      # --- Dropbear ---
      if [ -f /etc/default/dropbear ]; then
        sed -i '/DROPBEAR_BANNER/d' /etc/default/dropbear
        grep -q -- '-b /etc/banner' /etc/default/dropbear || \
          sed -i 's|^DROPBEAR_EXTRA_ARGS=.*|DROPBEAR_EXTRA_ARGS="-b /etc/banner"|' /etc/default/dropbear
        grep -q '^DROPBEAR_EXTRA_ARGS=' /etc/default/dropbear || echo 'DROPBEAR_EXTRA_ARGS="-b /etc/banner"' >> /etc/default/dropbear
      fi
      systemctl restart dropbear 2>/dev/null
      ok "Bannière ajoutée (sshd + dropbear)."
      printf "   ${GRY}Note : elle s'affiche si l'appli client montre la bannière SSH.${NC}\n"
      pause ;;
    2)
      rm -f /etc/banner
      sed -i '/^[#[:space:]]*Banner[[:space:]]/d' /etc/ssh/sshd_config
      systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null
      if [ -f /etc/default/dropbear ]; then
        sed -i 's|-b /etc/banner||g' /etc/default/dropbear
      fi
      systemctl restart dropbear 2>/dev/null
      ok "Bannière supprimée."; pause ;;
    *) return ;;
  esac
}
script_info(){
  header; center " ℹ️  À PROPOS " "${BOLD}${WHT}"; echo
  printf "   ${WHT}%s${NC}\n" "$BRAND"
  printf "   ${GRY}Panel de gestion premium multi-protocoles${NC}\n"
  printf "   ${CYN}Telegram : %s${NC}\n\n" "$CONTACT"
  printf "   ${GRY}Protocoles :${NC} SSH · SlowDNS · UDP · Vmess · Vless\n"
  printf "   ${GRY}             Trojan · Shadowsocks · WireGuard${NC}\n\n"
  printf "   ${GRY}Compatible :${NC} Ubuntu 20.04/22.04/24.04 · Debian 10/11/12\n"
  printf "   ${GRY}Architecture :${NC} x86_64 et ARM (aarch64)\n"
  printf "   ${GRY}RAM minimum :${NC} 1 Go\n"
  pause
}
reset_traffic(){
  header; warn "Cela remet à zéro les compteurs de consommation (hier/aujourd'hui/mois)."
  read -rp " Confirmer ? (o/n) : " r; confirm "$r" || { pause; return; }
  local ifc; ifc=$(ip route 2>/dev/null | awk '/default/{print $5; exit}')
  if [ -n "$ifc" ] && command -v vnstat >/dev/null 2>&1; then
    vnstat --remove -i "$ifc" --force >/dev/null 2>&1
    vnstat --add -i "$ifc" >/dev/null 2>&1
    systemctl restart vnstat >/dev/null 2>&1
    ok "Compteurs remis à zéro."
  else err "vnstat introuvable."; fi
  pause
}

while true; do
  header
  entry "1"  "🌐" "Ajouter / changer le domaine"
  entry "2"  "🔒" "Activer le TLS (HTTPS)"
  entry "3"  "⚙️" "Changer le port Dropbear"
  entry "4"  "💾" "Sauvegarde automatique"
  entry "5"  "📦" "Sauvegarder maintenant"
  entry "6"  "🔄" "Restaurer une sauvegarde"
  entry "7"  "📊" "Utilisation RAM / trafic"
  entry "8"  "🧠" "Créer un SwapRAM"
  entry "9"  "⚡" "Activer BBR"
  entry "10" "🚀" "Speedtest du serveur"
  entry "11" "♻️" "Redémarrer les services VPN"
  entry "12" "📜" "Renouveler les certificats"
  entry "13" "📝" "Ajouter une bannière SSH"
  entry "14" "ℹ️" "Info du script"
  entry "15" "🧹" "Réinitialiser la consommation"
  entry "0"  "⬅️" "Retour"
  line
  read -rp "$(printf " ${WHT}➤ Choix [0-15] :${NC} ")" o
  case "$o" in
    1) set_domain ;; 2) [ -s /etc/nvpanel/domain ] && install-tls || { err "Définis d'abord un domaine (option 1)."; pause; } ;;
    3) change_port ;; 4) autobackup ;; 5) backup_now ;; 6) restore_data ;;
    7) ram_usage ;; 8) swap_ram ;; 9) enable_bbr ;; 10) speedtest ;;
    11) restart_services ;; 12) renew_cert ;; 13) change_banner ;;
    14) script_info ;; 15) reset_traffic ;; 0) break ;;
    *) warn "Invalide"; sleep 1 ;;
  esac
done
