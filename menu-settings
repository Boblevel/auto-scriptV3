#!/bin/bash
# ============================================================
#  RHAFF SERVICE · Paramètres système   (commande : menu-settings)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
BKDIR=/root

header(){ banner; center " ⚙️  PARAMÈTRES SYSTÈME " "${BOLD}${WHT}"; line; }

set_domain(){
  header; center " 🌐  DOMAINE DU SERVEUR " "${BOLD}${WHT}"; line
  printf "   ${GRY}Actuel :${NC} %s\n\n" "$(cat /etc/nvpanel/domain 2>/dev/null || echo 'non configuré')"
  ask " Domaine complet (ex. vpn.mondomaine.com) : " d
  d=$(printf '%s' "$d" | tr -d '\r\n\t ' | tr 'A-Z' 'a-z')
  [ -z "$d" ] && { warn "Inchangé"; pause; return; }
  # Un domaine doit contenir au moins un point : « alfredtech » seul est invalide
  case "$d" in
    *.*) ;;
    *) err "Domaine incomplet : il manque l'extension (ex. $d.mondomaine.com)."; pause; return ;;
  esac
  echo "$d" > /etc/nvpanel/domain
  ok "Domaine enregistré : $d"
  echo

  # --- Propagation vers les modules qui dépendent du domaine ---
  # Sans ceci, SlowDNS garde l'ancien nom (il est inscrit dans son service).
  if systemctl is-active --quiet nvpanel-slowdns 2>/dev/null || [ -s /etc/nvpanel/slowdns/dns-server ]; then
    printf "${CYN}➜${NC} Reconfiguration de SlowDNS (ns-%s)…\n" "$d"
    /usr/local/bin/install-slowdns auto "ns-$d" >/dev/null 2>&1
    if systemctl is-active --quiet nvpanel-slowdns 2>/dev/null; then
      ok "SlowDNS mis à jour."
    else
      warn "SlowDNS n'a pas redémarré — réinstalle-le depuis le menu SSH."
    fi
  fi
  if command -v xray >/dev/null 2>&1 && [ -x /usr/local/bin/install-xray ]; then
    printf "${CYN}➜${NC} Mise à jour de la façade web…\n"
    /usr/local/bin/install-xray auto >/dev/null 2>&1
    ok "Façade web mise à jour."
  fi
  echo
  printf "   ${WHT}Pense à vérifier tes enregistrements DNS :${NC}\n"
  printf "   ${GRY}• A  : %s  →  %s${NC}\n" "${d%%.*}" "$(cat /etc/nvpanel/ip 2>/dev/null)"
  printf "   ${GRY}• NS : ns-%s  →  %s${NC}\n" "${d%%.*}" "$d"
  printf "   ${YLW}Les comptes déjà créés doivent être ré-envoyés (option « Revoir un compte »).${NC}\n"
  pause
}
change_port(){
  header; printf " ${GRY}Port Dropbear actuel :${NC} %s\n" "$(grep -oP 'DROPBEAR_PORT=\K[0-9]+' /etc/default/dropbear 2>/dev/null || echo '?')"
  ask " Nouveau port Dropbear : " p
  [[ "$p" =~ ^[0-9]+$ ]] || { err "Port invalide"; pause; return; }
  if grep -q DROPBEAR_PORT /etc/default/dropbear 2>/dev/null; then
    sed -i "s/^DROPBEAR_PORT=.*/DROPBEAR_PORT=$p/" /etc/default/dropbear
  else echo "DROPBEAR_PORT=$p" >> /etc/default/dropbear; fi
  systemctl restart dropbear 2>/dev/null; ok "Port Dropbear : $p"; pause
}
backup_now(){
  header; local f="$BKDIR/rhaff-backup-$(date +%F-%H%M).tar.gz"
  tar czf "$f" /etc/nvpanel /usr/local/etc/xray /etc/wireguard 2>/dev/null
  ok "Sauvegarde créée : $f"; pause
}
autobackup(){
  header
  ( crontab -l 2>/dev/null | grep -v rhaff-backup; echo "0 4 * * * tar czf $BKDIR/rhaff-backup-auto.tar.gz /etc/nvpanel /usr/local/etc/xray /etc/wireguard 2>/dev/null" ) | crontab -
  ok "Sauvegarde automatique activée (tous les jours à 4h)."; pause
}
restore_data(){
  header; local files=("$BKDIR"/rhaff-backup-*.tar.gz)
  [ -e "${files[0]}" ] || { err "Aucune sauvegarde trouvée"; pause; return; }
  local i=1; for f in "${files[@]}"; do printf "  ${GRN}%s)${NC} %s\n" "$i" "$(basename "$f")"; i=$((i+1)); done
  ask " Numéro à restaurer : " n
  local sel="${files[$((n-1))]}"
  [ -f "$sel" ] || { err "Choix invalide"; pause; return; }
  tar xzf "$sel" -C / && ok "Restauré depuis $(basename "$sel")"; pause
}
ram_usage(){ header; free -h; echo; command -v vnstat >/dev/null && vnstat --oneline 2>/dev/null; pause; }
swap_ram(){
  header; ask " Taille du swap en Mo (ex. 1024) : " s
  [[ "$s" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return; }
  fallocate -l "${s}M" /swapfile 2>/dev/null || dd if=/dev/zero of=/swapfile bs=1M count="$s" 2>/dev/null
  chmod 600 /swapfile; mkswap /swapfile >/dev/null 2>&1; swapon /swapfile 2>/dev/null
  grep -q '/swapfile' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
  ok "Swap de ${s} Mo activé."; pause
}
enable_bbr(){
  header
  grep -q 'net.core.default_qdisc=fq' /etc/sysctl.conf || echo 'net.core.default_qdisc=fq' >> /etc/sysctl.conf
  grep -q 'tcp_congestion_control=bbr' /etc/sysctl.conf || echo 'net.ipv4.tcp_congestion_control=bbr' >> /etc/sysctl.conf
  sysctl -p >/dev/null 2>&1
  local cc; cc=$(sysctl -n net.ipv4.tcp_congestion_control)
  [ "$cc" = "bbr" ] && ok "BBR activé." || warn "BBR demandé (contrôle : $cc). Un redémarrage peut être nécessaire."
  pause
}
speedtest(){
  header; center " 📶  TEST DE VITESSE DU SERVEUR " "${BOLD}${WHT}"; echo
  local lat; lat=$(ping -c 2 -W 2 1.1.1.1 2>/dev/null | awk -F'time=' '/time=/{gsub(/ ms/,"",$2); v=$2} END{print v}')
  printf "   ${GRY}📡 Latence  :${NC} ${WHT}%s ms${NC}\n" "${lat:-n/a}"
  printf "   ${GRY}⬇  Mesure du débit en cours…${NC}\n\n"

  local tmp; tmp=$(mktemp)
  # Mesure sur une DURÉE FIXE (8 s) : bien plus fiable qu'un petit fichier,
  # qui se termine en une fraction de seconde et gonfle le résultat.
  (
    for url in \
      "https://speed.cloudflare.com/__down?bytes=1000000000" \
      "https://proof.ovh.net/files/1Gb.dat" \
      "http://speedtest.tele2.net/1GB.zip" \
      "http://ipv4.download.thinkbroadband.com/512MB.zip" \
      "https://fra.download.datapacket.com/100mb.bin"; do
      res=$(curl -o /dev/null -sL --max-time 8 -w '%{size_download} %{time_total}' "$url" 2>/dev/null)
      dl=${res%% *}; tt=${res##* }
      sp=$(awk -v b="${dl:-0}" -v t="${tt:-0}" 'BEGIN{ if(t<=0){print 0} else {printf "%d", b/t} }')
      if awk -v b="${sp:-0}" 'BEGIN{exit !(b>50000)}'; then echo "$sp" > "$tmp"; break; fi
    done
  ) &
  local pid=$! i=0
  local frames=( "▰▱▱▱▱▱" "▱▰▱▱▱▱" "▱▱▰▱▱▱" "▱▱▱▰▱▱" "▱▱▱▱▰▱" "▱▱▱▱▱▰" "▱▱▱▱▰▱" "▱▱▱▰▱▱" "▱▱▰▱▱▱" "▱▰▱▱▱▱" )
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r   ${CYN}[${GRN}%s${CYN}]${NC}  ${GRY}analyse du réseau…${NC}   " "${frames[i % ${#frames[@]}]}"
    i=$((i+1)); sleep 0.12
  done
  wait "$pid" 2>/dev/null
  local sp; sp=$(cat "$tmp" 2>/dev/null); rm -f "$tmp"
  printf "\r%-52s\r" " "
  if [ -n "$sp" ] && awk -v b="$sp" 'BEGIN{exit !(b>50000)}'; then
    local mbps mbs; mbps=$(awk -v b="$sp" 'BEGIN{printf "%.1f", b*8/1000000}')
    mbs=$(awk -v b="$sp" 'BEGIN{printf "%.1f", b/1048576}')
    line
    printf "   ${GRN}✔ Débit descendant :${NC} ${WHT}%s Mbps${NC}  ${GRY}(%s Mo/s)${NC}\n" "$mbps" "$mbs"
    printf "   ${GRY}   Latence : %s ms${NC}\n\n" "${lat:-n/a}"
    printf "   ${GRY}Il s'agit de la vitesse de TON SERVEUR vers Internet,${NC}\n"
    printf "   ${GRY}pas de la vitesse ressentie par un client dans le tunnel${NC}\n"
    printf "   ${GRY}(elle dépend aussi de sa connexion mobile).${NC}\n"
  else
    err "Aucune source de test n'a répondu (réseau du serveur restreint ou pare-feu)."
    printf "   ${GRY}Latence mesurée : %s ms${NC}\n" "${lat:-n/a}"
  fi
  pause
}
restart_services(){
  header; center " ♻️  REDÉMARRAGE DES SERVICES " "${BOLD}${WHT}"; line
  local s name pair done=0
  for pair in \
    "ssh:SSH (OpenSSH)" "dropbear:Dropbear" "xray:Xray" "nginx:Nginx (TLS/WS)" \
    "nvpanel-slowdns:SlowDNS" "nvpanel-badvpn-7100:UDP 7100" "nvpanel-badvpn-7200:UDP 7200" \
    "nvpanel-badvpn-7300:UDP 7300" "nvpanel-udp-custom:UDP custom" "wg-quick@wg0:WireGuard" \
    "nvpanel-limit:Limite d'appareils" "nvpanel-bot:Bot Telegram"; do
    s="${pair%%:*}"; name="${pair##*:}"
    if systemctl is-active --quiet "$s" 2>/dev/null || systemctl is-enabled --quiet "$s" 2>/dev/null; then
      if systemctl restart "$s" >/dev/null 2>&1; then
        printf "   ${GRN}✔ redémarré  ${NC} %s\n" "$name"; done=$((done+1))
      else
        printf "   ${RED}✘ échec      ${NC} %s\n" "$name"
      fi
    else
      printf "   ${GRY}– non installé${NC} ${GRY}%s${NC}\n" "$name"
    fi
  done
  echo; ok "$done service(s) redémarré(s)."
  pause
}
renew_cert(){
  header; center " 📜  RENOUVELLEMENT DES CERTIFICATS " "${BOLD}${WHT}"; line
  if ! command -v certbot >/dev/null 2>&1; then
    err "certbot n'est pas installé (le TLS n'a jamais été activé)."; pause; return
  fi
  if ! ls /etc/letsencrypt/live/*/fullchain.pem >/dev/null 2>&1; then
    warn "Aucun certificat Let's Encrypt trouvé."
    printf "   ${GRY}Active d'abord le TLS (Paramètres → option 2) pour obtenir un certificat.${NC}\n"
    pause; return
  fi
  printf "${CYN}➜${NC} Vérification et renouvellement…\n\n"
  local out; out=$(certbot renew --non-interactive 2>&1)
  systemctl reload nginx >/dev/null 2>&1
  if echo "$out" | grep -qiE 'not yet due|no renewals|no certificates'; then
    ok "Certificat encore valide — aucun renouvellement nécessaire."
  elif echo "$out" | grep -qiE 'renewed|congratulations|successfully'; then
    ok "Certificat renouvelé avec succès."
  else
    ok "Vérification terminée."
  fi
  local c d exp
  for c in /etc/letsencrypt/live/*/cert.pem; do
    [ -f "$c" ] || continue
    d=$(basename "$(dirname "$c")")
    exp=$(openssl x509 -enddate -noout -in "$c" 2>/dev/null | cut -d= -f2)
    printf "   ${GRY}%s${NC} → expire le ${WHT}%s${NC}\n" "$d" "$exp"
  done
  pause
}
change_banner(){
  header
  printf "   ${WHT}Bannière / message client${NC}\n   ${GRY}SSH : affichée à la connexion · Autres protocoles : affichée${NC}\n   ${GRY}comme description de la connexion dans l'appli.${NC}\n"
  printf "   ${GRY}Actuelle :${NC} %s\n\n" "$([ -s /etc/banner ] && head -1 /etc/banner || echo 'aucune')"
  entry "1" "➕" "Ajouter / modifier la bannière"
  entry "2" "🗑️" "Supprimer la bannière"
  entry "0" "⬅️" "Retour"
  line; ask "$(printf " ${WHT}➤ Choix :${NC} ")" b
  case "$b" in
    1)
      echo; printf "   ${GRY}Saisis ton texte (une ligne). Entrée pour valider.${NC}\n"
      ask "   Texte : " txt
      [ -z "$txt" ] && { warn "Inchangé"; pause; return; }
      printf '%s\n' "$txt" > /etc/banner
      chmod 644 /etc/banner
      cp -f /etc/banner /etc/issue.net 2>/dev/null

      # --- OpenSSH : affiche la bannière AVANT l'authentification ---
      sed -i '/^[#[:space:]]*Banner[[:space:]]/d' /etc/ssh/sshd_config
      echo 'Banner /etc/banner' >> /etc/ssh/sshd_config
      systemctl restart ssh >/dev/null 2>&1 || systemctl restart sshd >/dev/null 2>&1

      # --- Dropbear : option -b (utilisé par les tunnels WebSocket/SSL) ---
      touch /etc/default/dropbear 2>/dev/null
      sed -i '/DROPBEAR_BANNER/d' /etc/default/dropbear
      if grep -q '^DROPBEAR_EXTRA_ARGS=' /etc/default/dropbear; then
        grep -q -- '-b /etc/banner' /etc/default/dropbear || \
          sed -i 's|^DROPBEAR_EXTRA_ARGS="\?\(.*\)"\?$|DROPBEAR_EXTRA_ARGS="\1 -b /etc/banner"|' /etc/default/dropbear
      else
        echo 'DROPBEAR_EXTRA_ARGS="-b /etc/banner"' >> /etc/default/dropbear
      fi
      systemctl restart dropbear >/dev/null 2>&1
      sleep 1

      # Certains systèmes ignorent /etc/default/dropbear : filet de sécurité
      # → on force l'option directement dans le service systemd.
      if systemctl is-active --quiet dropbear 2>/dev/null && ! pgrep -af dropbear 2>/dev/null | grep -q -- '-b /etc/banner'; then
        local ex
        ex=$(systemctl show -p ExecStart --value dropbear 2>/dev/null | sed -n 's/.*argv\[\]=\([^;]*\).*/\1/p' | head -1)
        if [ -n "$ex" ]; then
          mkdir -p /etc/systemd/system/dropbear.service.d
          printf '[Service]\nExecStart=\nExecStart=%s -b /etc/banner\n' "$ex" \
            > /etc/systemd/system/dropbear.service.d/nvpanel-banner.conf
          systemctl daemon-reload >/dev/null 2>&1
          systemctl restart dropbear >/dev/null 2>&1
          sleep 1
        fi
      fi

      ok "Bannière enregistrée."
      echo
      if pgrep -af dropbear 2>/dev/null | grep -q -- '-b /etc/banner'; then
        printf "   ${GRN}✔${NC} Dropbear  ${GRY}(SSH WebSocket / SSL)${NC}\n"
      else
        printf "   ${YLW}–${NC} Dropbear  ${GRY}(non actif sur ce serveur)${NC}\n"
      fi
      grep -q '^Banner /etc/banner' /etc/ssh/sshd_config && \
        printf "   ${GRN}✔${NC} OpenSSH   ${GRY}(SSH direct, SlowDNS, UDP)${NC}\n"
      printf "   ${GRN}✔${NC} Vmess · Vless · Trojan · Shadowsocks · WireGuard\n"
      printf "       ${GRY}(le texte apparaît comme description de la connexion)${NC}\n"
      echo
      printf "   ${WHT}Important :${NC} ${GRY}les comptes DÉJÀ créés doivent être ré-envoyés${NC}\n"
      printf "   ${GRY}au client. Va dans le protocole → « Revoir un compte » :${NC}\n"
      printf "   ${GRY}le lien régénéré contiendra le nouveau texte.${NC}\n"
      pause ;;
    2)
      rm -f /etc/banner
      sed -i '/^[#[:space:]]*Banner[[:space:]]/d' /etc/ssh/sshd_config
      systemctl restart ssh >/dev/null 2>&1 || systemctl restart sshd >/dev/null 2>&1
      [ -f /etc/default/dropbear ] && sed -i 's| *-b /etc/banner||g' /etc/default/dropbear
      rm -f /etc/systemd/system/dropbear.service.d/nvpanel-banner.conf
      systemctl daemon-reload >/dev/null 2>&1
      systemctl restart dropbear >/dev/null 2>&1
      ok "Bannière supprimée."; pause ;;
    *) return ;;
  esac
}
script_info(){
  header; center " ℹ️  À PROPOS " "${BOLD}${WHT}"; echo
  printf "   ${WHT}%s${NC}\n" "$BRAND"
  printf "   ${GRY}Panel de gestion premium multi-protocoles${NC}\n"
  printf "   ${CYN}Telegram : %s${NC}\n\n" "$CONTACT"
  printf "   ${GRY}Protocoles :${NC} SSH · SlowDNS · UDP · Vmess · Vless\n"
  printf "   ${GRY}             Trojan · Shadowsocks · WireGuard${NC}\n\n"
  printf "   ${GRY}Compatible :${NC} Ubuntu 20.04/22.04/24.04 · Debian 10/11/12\n"
  printf "   ${GRY}Architecture :${NC} x86_64 et ARM (aarch64)\n"
  printf "   ${GRY}RAM minimum :${NC} 1 Go\n"
  pause
}
reset_traffic(){
  header; center " 🧹  RÉINITIALISER LA CONSOMMATION " "${BOLD}${WHT}"; line
  warn "Remet à zéro les compteurs (hier / aujourd'hui / mois)."
  printf "   ${RED}➤ Confirmer ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }
  echo
  # 1) compteur de trafic CLIENT du panel
  printf "${CYN}➜${NC} Compteurs du panel…\n"
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso reset >/dev/null 2>&1
  rm -f /etc/nvpanel/db/conso /etc/nvpanel/db/conso.tmp 2>/dev/null
  touch /etc/nvpanel/db/conso
  # 2) compteurs de quota par compte
  printf "${CYN}➜${NC} Quotas par compte…\n"
  : > /etc/nvpanel/db/quota_used 2>/dev/null
  iptables -Z NVPANEL_QUOTA >/dev/null 2>&1
  # 3) vnstat (utilisé en secours par l'affichage)
  printf "${CYN}➜${NC} Statistiques réseau…\n"
  local ifc; ifc=$(ip route 2>/dev/null | awk '/default/{print $5; exit}')
  if [ -n "$ifc" ] && command -v vnstat >/dev/null 2>&1; then
    systemctl stop vnstat >/dev/null 2>&1
    vnstat --remove -i "$ifc" --force >/dev/null 2>&1
    rm -f /var/lib/vnstat/"$ifc" /var/lib/vnstat/vnstat.db 2>/dev/null
    vnstat --add -i "$ifc" >/dev/null 2>&1
    systemctl start vnstat >/dev/null 2>&1
  fi
  # 4) on relance les chaînes pour repartir de zéro
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1
  echo
  ok "Tous les compteurs sont à zéro."
  printf "   ${GRY}Vérifié : historique vidé, compteurs réseau remis à zéro,${NC}\n"
  printf "   ${GRY}quotas des comptes réinitialisés.${NC}\n"
  pause
}

while true; do
  header
  entry "1"  "🌐" "Ajouter / changer le domaine"
  entry "2"  "🔒" "Activer le TLS (HTTPS)"
  entry "3"  "⚙️" "Changer le port Dropbear"
  entry "4"  "💾" "Sauvegarde automatique"
  entry "5"  "📦" "Sauvegarder maintenant"
  entry "6"  "🔄" "Restaurer une sauvegarde"
  entry "7"  "📊" "Utilisation RAM / trafic"
  entry "8"  "🧠" "Créer un SwapRAM"
  entry "9"  "⚡" "Activer BBR"
  entry "10" "🚀" "Test de vitesse du serveur"
  entry "11" "♻️" "Redémarrer les services VPN"
  entry "12" "📜" "Renouveler les certificats"
  entry "13" "📝" "Ajouter une bannière SSH"
  entry "14" "ℹ️" "Info du script"
  entry "15" "🧹" "Réinitialiser la consommation"
  entry "0"  "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}➤ Choix [0-15] :${NC} ")" o
  case "$o" in
    1) set_domain ;; 2) [ -s /etc/nvpanel/domain ] && install-tls || { err "Définis d'abord un domaine (option 1)."; pause; } ;;
    3) change_port ;; 4) autobackup ;; 5) backup_now ;; 6) restore_data ;;
    7) ram_usage ;; 8) swap_ram ;; 9) enable_bbr ;; 10) speedtest ;;
    11) restart_services ;; 12) renew_cert ;; 13) change_banner ;;
    14) script_info ;; 15) reset_traffic ;; 0) break ;;
    *) warn "Invalide"; sleep 1 ;;
  esac
done
