#!/bin/bash
# ============================================================
#  RHAFF SERVICE · SlowDNS (dnstt) — clé FIXE hébergée
#  Le binaire + la paire de clés viennent de ton dépôt GitHub,
#  donc la clé publique est la même chez tous tes clients
#  (comme Nevermore). Chaque client configure seulement son NS.
#  Usage :
#    install-slowdns            (interactif : demande le NS)
#    install-slowdns auto <NS>  (non-interactif : utilisé à l'install)
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

REPO_RAW="https://raw.githubusercontent.com/Boblevel/auto-scriptV3/main"
DIR=/etc/nvpanel/slowdns
mkdir -p "$DIR"

AUTO=0; NS_ARG=""
[ "$1" = "auto" ] && { AUTO=1; NS_ARG="$2"; }

# --- Récupère le binaire (selon l'architecture) + les clés fixes ---
case "$(uname -m)" in
  aarch64|arm64) BIN_SRC="dns-server-arm64" ;;
  *)             BIN_SRC="dns-server" ;;
esac
dl(){ curl -fsSL "$REPO_RAW/$1" -o "$2" 2>/dev/null; }
[ -s "$DIR/dns-server" ] || dl "$BIN_SRC" "$DIR/dns-server"
[ -s "$DIR/server.key" ] || dl server.key "$DIR/server.key"
[ -s "$DIR/server.pub" ] || dl server.pub "$DIR/server.pub"
chmod +x "$DIR/dns-server" 2>/dev/null

if [ ! -s "$DIR/dns-server" ] || [ ! -s "$DIR/server.key" ]; then
  if [ "$AUTO" = 0 ]; then err "Le module SlowDNS n'a pas pu être installé. Vérifie la connexion du serveur puis réessaie."; pause; fi
  exit 1
fi

# --- Nameserver (NS) ----------------------------------------
if [ "$AUTO" = 1 ]; then
  NS="$NS_ARG"
else
  banner; center " 🌐  INSTALLATION SLOWDNS " "${BOLD}${WHT}"; line
  DOM=$(cat /etc/nvpanel/domain 2>/dev/null)
  [ -n "$DOM" ] && printf " ${GRY}Suggestion pour ton domaine :${NC} ${WHT}ns-%s${NC}\n\n" "$DOM"
  read -rp " Nameserver (NS, ex. ns-mondomaine.com) : " NS
fi
[ -z "$NS" ] && { [ "$AUTO" = 0 ] && { err "NS requis"; pause; }; exit 1; }
echo "$NS" > "$DIR/ns"

# --- Redirection UDP 53 -> 5300 -----------------------------
iptables -I INPUT -p udp --dport 5300 -j ACCEPT 2>/dev/null
iptables -t nat -C PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null \
  || iptables -t nat -A PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null

# --- Service (forward vers le SSH local sur 22) -------------
cat > /etc/systemd/system/nvpanel-slowdns.service <<EOF
[Unit]
Description=RHAFF SlowDNS (dnstt)
After=network.target
[Service]
ExecStart=$DIR/dns-server -udp :5300 -privkey-file $DIR/server.key $NS 127.0.0.1:22
Restart=always
User=root
[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now nvpanel-slowdns >/dev/null 2>&1

if [ "$AUTO" = 1 ]; then
  printf "  ${GRN}✔${NC} SlowDNS prêt (NS: %s)\n" "$NS"
  exit 0
fi

PUB=$(cat "$DIR/server.pub")
clear; banner; center " 🌐  SLOWDNS PRÊT " "${BOLD}${GRN}"; line
ok "Service actif."
echo
printf "   ${GRY}À configurer chez ton registrar DNS :${NC}\n"
printf "   • ${WHT}%s${NC}   →  enregistrement ${WHT}A${NC}  vers ${WHT}%s${NC}\n" "$NS" "$(cat /etc/nvpanel/ip 2>/dev/null)"
printf "   • un sous-domaine  →  enregistrement ${WHT}NS${NC}  vers ${WHT}%s${NC}\n" "$NS"
echo
printf "   ${GRY}Clé publique (dans chaque compte SSH) :${NC}\n   ${WHT}%s${NC}\n" "$PUB"
pause
