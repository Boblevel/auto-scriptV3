#!/bin/bash
# ============================================================
#  RHAFF SERVICE · désinstallation du script  (commande : menu-uninstall)
# ============================================================
source /etc/nvpanel/lib/ui.sh 2>/dev/null || { RED='\033[0;31m'; GRN='\033[0;32m'; NC='\033[0m'; }
[ "$EUID" -ne 0 ] && { echo "Lance en root."; exit 1; }

clear
printf "${RED}"
cat <<'ART'
   ┌───────────────────────────────────────────────────────┐
   │     DESINSTALLATION DE  R H A F F   S E R V I C E     │
   └───────────────────────────────────────────────────────┘
ART
printf "${NC}\n"
echo " Cette action va supprimer : le panel, le bot, les services"
echo " (SlowDNS, UDP, Xray, limite, quota) et toutes les données."
echo
read -rp " Confirmer la désinstallation ? (tape OUI) : " c
[ "$c" != "OUI" ] && { echo "Annulé."; exit 0; }

read -rp " Supprimer aussi les comptes SSH créés ? (o/n) : " delusers
read -rp " Désinstaller aussi le cœur Xray ? (o/n) : " delxray

echo; printf "${RED}➜ Suppression en cours…${NC}\n"

# 1) Services systemd
for s in nvpanel-slowdns nvpanel-udp-custom nvpanel-limit nvpanel-bot \
         nvpanel-badvpn-7100 nvpanel-badvpn-7200 nvpanel-badvpn-7300; do
  systemctl disable --now "$s" >/dev/null 2>&1
  rm -f "/etc/systemd/system/$s.service"
done
systemctl disable --now wg-quick@wg0 >/dev/null 2>&1
systemctl daemon-reload >/dev/null 2>&1

# 2) Tâches cron
( crontab -l 2>/dev/null | grep -v -E 'nvpanel-clean|nvpanel-quota' ) | crontab - 2>/dev/null

# 3) Comptes SSH (optionnel)
if [ "$delusers" = "o" ]; then
  awk -F: '$3>=1000 && $3<60000 {print $1}' /etc/passwd | while read -r u; do
    userdel -f "$u" >/dev/null 2>&1
  done
fi

# 4) Règles iptables (quota + slowdns)
iptables -F NVPANEL_QUOTA 2>/dev/null
iptables -D OUTPUT -j NVPANEL_QUOTA 2>/dev/null
iptables -X NVPANEL_QUOTA 2>/dev/null
iptables -t nat -D PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null

# 4b) Vhost nginx du panel
rm -f /etc/nginx/conf.d/nvpanel.conf /etc/nginx/conf.d/rhaff-http.conf /etc/nginx/conf.d/rhaff-tls.conf /etc/nginx/nvpanel-ws.conf
systemctl reload nginx 2>/dev/null

# 5) Cœur Xray (optionnel)
if [ "$delxray" = "o" ]; then
  bash <(curl -sL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) remove --purge >/dev/null 2>&1
fi

# 6) Binaires et raccourcis
rm -f /usr/local/bin/{menu,acc,dgh,menu-ssh,menu-bot,menu-xray,menu-ss,menu-wg,menu-settings,menu-uninstall,uninstall,update} \
      /usr/local/bin/{nvpanel-cli,nvpanel-bot,nvpanel-limit,nvpanel-quota,nvpanel-clean} \
      /usr/local/bin/{install-slowdns,install-udp,install-xray,install-tls}

# 7) Données
rm -rf /etc/nvpanel

clear
printf "${GRN}✔ RHAFF SERVICE a été entièrement désinstallé.${NC}\n"
echo "  (les paquets système comme dropbear/nginx ne sont pas touchés)"
echo
