#!/bin/bash
# ============================================================
#  RHAFF SERVICE · désinstallation / réinitialisation complète
#  (commande : menu-uninstall  ·  alias : uninstall)
#  Supprime TOUT : panel, bot, services, comptes, Xray,
#  WireGuard, règles réseau, nginx et données.
# ============================================================
source /etc/nvpanel/lib/ui.sh 2>/dev/null || { RED='\033[0;31m'; GRN='\033[0;32m'; YLW='\033[0;33m'; NC='\033[0m'; }
[ "$EUID" -ne 0 ] && { echo "Lance en root."; exit 1; }

# réponse affirmative insensible à la casse (oui/OUI/Oui/o/O/y/yes…)
_yes(){ case "${1,,}" in oui|o|y|yes) return 0;; *) return 1;; esac; }

clear
printf "${RED}"
cat <<'ART'
   ┌───────────────────────────────────────────────────────┐
   │     DESINSTALLATION DE  R H A F F   S E R V I C E     │
   └───────────────────────────────────────────────────────┘
ART
printf "${NC}\n"
echo " Cette action supprime et réinitialise TOUT :"
echo " panel, bot, services, comptes SSH, Xray, WireGuard,"
echo " règles réseau, configs nginx et toutes les données."
echo
ask " Confirmer la désinstallation complète ? (tape OUI) : " c
_yes "$c" || { echo "Annulé."; exit 0; }

echo; printf "${RED}➜ Suppression complète en cours…${NC}\n"

# 1) Comptes SSH gérés
if [ -f /etc/nvpanel/db/ssh ]; then
  while read -r _ u _; do [ -n "$u" ] && userdel -f "$u" 2>/dev/null; done < /etc/nvpanel/db/ssh
fi

# 2) Services systemd
for s in nvpanel-slowdns nvpanel-udp-custom nvpanel-limit nvpanel-bot \
         nvpanel-badvpn-7100 nvpanel-badvpn-7200 nvpanel-badvpn-7300 wg-quick@wg0; do
  systemctl disable --now "$s" >/dev/null 2>&1
  rm -f "/etc/systemd/system/$s.service"
done
systemctl daemon-reload >/dev/null 2>&1

# 3) Tâches cron
( crontab -l 2>/dev/null | grep -v -E 'nvpanel-clean|nvpanel-quota|nvpanel-conso|rhaff-backup' ) | crontab - 2>/dev/null

# 4) Règles iptables + configs nginx
iptables -F NVPANEL_QUOTA 2>/dev/null
iptables -D OUTPUT -j NVPANEL_QUOTA 2>/dev/null
iptables -X NVPANEL_QUOTA 2>/dev/null
# protocoles PPP (L2TP / PPTP / SSTP)
for u in xl2tpd pptpd nvpanel-sstp strongswan-starter strongswan; do
  systemctl disable --now "$u" >/dev/null 2>&1
done
rm -f /etc/systemd/system/nvpanel-sstp.service
rm -f /etc/ppp/options.xl2tpd /etc/ppp/options.sstpd /etc/ppp/pptpd-options
rm -rf /etc/nvpanel/sstp /etc/nvpanel/l2tp_psk /etc/nvpanel/sstp_port
sed -i '/[[:space:]]\(l2tpd\|pptpd\|sstpd\)[[:space:]]/d' /etc/ppp/chap-secrets 2>/dev/null
[ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso remove 2>/dev/null
iptables -t nat -D PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null
rm -f /etc/nginx/conf.d/nvpanel.conf /etc/nginx/conf.d/rhaff-http.conf \
      /etc/nginx/conf.d/rhaff-tls.conf /etc/nginx/conf.d/rhaff.conf /etc/nginx/nvpanel-ws.conf
systemctl reload nginx 2>/dev/null

# 5) WireGuard (config créée par le script)
rm -f /etc/wireguard/wg0.conf

# 6) Cœur Xray (purge automatique s'il est présent)
if command -v xray >/dev/null 2>&1; then
  printf "${YLW}➜ Suppression du cœur Xray…${NC}\n"
  bash <(curl -sL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) remove --purge >/dev/null 2>&1
fi
rm -rf /usr/local/etc/xray

# 7) Binaires, raccourcis et données
rm -f /usr/local/bin/{menu,acc,dgh,menu-ssh,menu-xray,menu-ss,menu-wg,menu-bot,menu-settings,menu-uninstall,uninstall,update} \
      /usr/local/bin/{nvpanel-cli,nvpanel-bot,nvpanel-limit,nvpanel-quota,nvpanel-clean,nvpanel-conso,nvpanel-ppp} \
      /usr/local/bin/{install-slowdns,install-udp,install-xray,install-tls}
rm -rf /etc/nvpanel

# On quitte l'écran séparé AVANT le message final, sinon il serait effacé
# en même temps que l'affichage du panel.
type ui_screen_off >/dev/null 2>&1 && ui_screen_off
clear
printf "${GRN}✔ RHAFF SERVICE a été entièrement supprimé et réinitialisé.${NC}\n"
echo "  (les paquets système de base comme nginx/dropbear ne sont pas touchés)"
echo
