#!/bin/bash
# ============================================================
#  nvpanel · gestion SSH (+ SlowDNS, UDP, limite, quota)
#  commande : menu-ssh
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

DB=/etc/nvpanel/db/ssh
LIMDB=/etc/nvpanel/db/limit
QDB=/etc/nvpanel/db/quota
mkdir -p /etc/nvpanel/db; touch "$DB" "$LIMDB" "$QDB"
IP=$(cat /etc/nvpanel/ip 2>/dev/null)
DOMAIN=$(cat /etc/nvpanel/domain 2>/dev/null || echo "$IP")

header(){ banner; center " GESTION SSH / SLOWDNS / UDP " "${BOLD}${WHT}"; line; }

# Sélecteur : liste les comptes SSH gérés et renvoie celui choisi par numéro.
# Résultat dans la variable PICK. Retour 1 si annulé / aucun compte.
pick_user() {
  PICK=""
  mapfile -t _users < <(awk '/^### /{print $2}' "$DB" 2>/dev/null)
  if [ "${#_users[@]}" -eq 0 ]; then err "Aucun compte SSH."; pause; return 1; fi
  echo; printf "   ${GRY}Comptes disponibles :${NC}\n"
  local i=1 u exp st
  for u in "${_users[@]}"; do
    exp=$(awk -v x="$u" '$2==x{print $3}' "$DB")
    if passwd -S "$u" 2>/dev/null | awk '{exit !($2=="L")}'; then st="${RED}verrou${NC}"; else st="${GRN}actif${NC}"; fi
    printf "   ${WHT}%2d${NC}) %-16s ${GRY}exp %s${NC}  %b\n" "$i" "$u" "${exp:-?}" "$st"
    i=$((i+1))
  done
  echo; read -rp "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_users[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_users[$((n-1))]}"; return 0
}

create_account() {
  header
  read -rp " Utilisateur : " user
  [ -z "$user" ] && { err "Nom vide"; pause; return; }
  id "$user" &>/dev/null && { err "Existe déjà"; pause; return; }
  read -rp " Mot de passe : " pass
  read -rp " Durée (jours) : " days;   [[ "$days" =~ ^[0-9]+$ ]] || days=30
  read -rp " Limite d'appareils : " lim; [[ "$lim" =~ ^[0-9]+$ ]] || lim=2
  read -rp " Quota (Go, 0 = illimité) : " gb; [[ "$gb" =~ ^[0-9]+$ ]] || gb=0

  out=$(nvpanel-cli create "$user" "$pass" "$days" "$lim" "$gb")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Compte SSH créé"
    echo
    printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
    printf "\n   ${GRY}Appareils : %s · Quota : %s${NC}\n" "$lim" "$([ "$gb" -gt 0 ] && echo "${gb} Go" || echo illimité)"
  else
    err "Échec : $(echo "$out" | head -1)"
  fi
  pause

}

list_accounts() {
  header
  printf " ${GRY}%-14s %-11s %-4s %-9s %s${NC}\n" "User" "Expire" "Dev" "Quota" "Statut"
  line
  awk -F: '$3>=1000 && $3<60000 {print $1}' /etc/passwd | while read -r u; do
    e=$(chage -l "$u" 2>/dev/null | awk -F: '/Account expires/{print $2}' | xargs)
    l=$(awk -v u="$u" '$1==u{print $2}' "$LIMDB"); l=${l:-–}
    q=$(awk -v u="$u" '$1==u{printf "%dGo",$2/1073741824}' "$QDB"); q=${q:-illim}
    if passwd -S "$u" 2>/dev/null | grep -q ' L '; then st="${RED}verrou${NC}"; else st="${GRN}actif${NC}"; fi
    printf " %-14s %-11s %-4s %-9s %b\n" "$u" "${e:-jamais}" "$l" "$q" "$st"
  done
  pause
}

renew_account() {
  header; pick_user || return; user="$PICK"
  read -rp " Ajouter (jours) : " days; [[ "$days" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return; }
  out=$(nvpanel-cli renew "$user" "$days")
  echo "$out" | grep -q '^OK' && ok "$user prolongé (compteur quota remis à zéro)" || err "Échec : $out"
  pause
}

delete_account() {
  header; pick_user || return; user="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$user"; read -r c
  confirm "$c" || { pause; return; }
  out=$(nvpanel-cli delete "$user")
  echo "$out" | grep -q '^OK' && ok "$user supprimé (connexion coupée)" || err "Échec : $out"
  pause
}

lock_toggle() {
  header; pick_user || return; user="$PICK"
  if passwd -S "$user" 2>/dev/null | awk '{exit !($2=="L")}'; then
    nvpanel-cli unlock "$user" >/dev/null; ok "$user déverrouillé"
  else
    nvpanel-cli lock "$user" >/dev/null; ok "$user verrouillé (connexion coupée)"
  fi
  pause
}

slowdns_menu() {
  header
  if systemctl is-active --quiet nvpanel-slowdns; then
    ok "SlowDNS actif"
    printf "   NS  : ${WHT}%s${NC}\n" "$(cat /etc/nvpanel/slowdns/ns 2>/dev/null)"
    printf "   Pub : ${WHT}%s${NC}\n" "$(cat /etc/nvpanel/slowdns/server.pub 2>/dev/null)"
  else
    warn "SlowDNS non installé."
  fi
  echo; entry "1" "Installer / réinstaller SlowDNS"; entry "0" "⬅️" "Retour"; line
  read -rp " Choix : " s
  [ "$s" = "1" ] && install-slowdns
}

udp_status() {
  header
  for p in 7100 7200 7300; do
    if systemctl is-active --quiet nvpanel-badvpn-$p; then ok "badvpn $p actif"; else warn "badvpn $p inactif"; fi
  done
  systemctl is-active --quiet nvpanel-udp-custom && ok "udp-custom actif" || warn "udp-custom inactif"
  echo; entry "1" "Installer / réinstaller UDP"; entry "0" "⬅️" "Retour"; line
  read -rp " Choix : " s
  [ "$s" = "1" ] && install-udp
}

while true; do
  header
  entry "1" "➕" "Créer un compte"
  entry "2" "📋" "Lister les comptes"
  entry "3" "♻️" "Prolonger / réactiver"
  entry "4" "🔒" "Verrouiller / déverrouiller"
  entry "5" "🗑️" "Supprimer un compte"
  entry "6" "🌐" "SlowDNS"
  entry "7" "📡" "UDP (badvpn / udp-custom)"
  entry "0" "⬅️" "Retour"
  line
  read -rp "$(printf " ${WHT}Choix :${NC} ")" o
  case "$o" in
    1) create_account ;; 2) list_accounts ;; 3) renew_account ;;
    4) lock_toggle ;;   5) delete_account ;; 6) slowdns_menu ;;
    7) udp_status ;;    0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
