#!/bin/bash
# ============================================================
#  nvpanel · gestion SSH (+ SlowDNS, UDP, limite, quota)
#  commande : menu-ssh
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

DB=/etc/nvpanel/db/ssh
LIMDB=/etc/nvpanel/db/limit
QDB=/etc/nvpanel/db/quota
mkdir -p /etc/nvpanel/db; touch "$DB" "$LIMDB" "$QDB"
IP=$(cat /etc/nvpanel/ip 2>/dev/null)
DOMAIN=$(cat /etc/nvpanel/domain 2>/dev/null || echo "$IP")

header(){ banner; center " GESTION SSH / SLOWDNS / UDP " "${BOLD}${WHT}"; line; proto_dash ssh ssh; line; }

# Sélecteur : liste les comptes SSH gérés et renvoie celui choisi par numéro.
# Résultat dans la variable PICK. Retour 1 si annulé / aucun compte.
pick_user() {
  PICK=""
  mapfile -t _users < <(awk '/^### /{print $2}' "$DB" 2>/dev/null)
  if [ "${#_users[@]}" -eq 0 ]; then err "Aucun compte SSH."; pause; return 1; fi
  echo; printf "   ${GRY}Comptes disponibles :${NC}\n"
  local i=1 u exp st
  for u in "${_users[@]}"; do
    exp=$(awk -v x="$u" '$2==x{print $3}' "$DB")
    if passwd -S "$u" 2>/dev/null | awk '{exit !($2=="L")}'; then st="${RED}verrou${NC}"; else st="${GRN}actif${NC}"; fi
    local _ct; _ct=$(_conn_time "$u")
    printf "   ${WHT}%2d${NC}) %-16s ${GRY}exp %s${NC}  %b  ${CYN}%s${NC}\n" "$i" "$u" "${exp:-?}" "$st" "${_ct:+⏱ $_ct}"
    i=$((i+1))
  done
  echo; ask "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_users[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_users[$((n-1))]}"; return 0
}

create_account() {
  # Sans argument : saisie interactive. Avec arguments : création automatique
  # (utilisée par le compte test 24 h).
  local user pass days lim gb out
  if [ -n "$1" ]; then
    user="$1"; pass="$2"; days="${3:-1}"; lim="${4:-1}"; gb="${5:-0}"
  else
    header
    ask " Utilisateur : " user
    [ -z "$user" ] && { err "Nom vide"; pause; return; }
    id "$user" &>/dev/null && { err "Existe déjà"; pause; return; }
    ask " Mot de passe : " pass
    ask " Durée (jours) : " days;   [[ "$days" =~ ^[0-9]+$ ]] || days=30
    ask " Limite d'appareils : " lim; [[ "$lim" =~ ^[0-9]+$ ]] || lim=2
    ask " Quota (Go, 0 = illimité) : " gb; [[ "$gb" =~ ^[0-9]+$ ]] || gb=0
  fi
  out=$(nvpanel-cli create "$user" "$pass" "$days" "$lim" "$gb")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Compte SSH créé"
    echo
    printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else
    case "$out" in
      *shortpass*) err "Mot de passe trop court : 4 caractères minimum." ;;
      *exists*)    err "Ce nom d'utilisateur existe déjà." ;;
      *)           err "Échec : $(echo "$out" | head -1)" ;;
    esac
  fi
  pause

}

list_accounts() {
  header
  printf " ${WHT}%-16s %-12s %-8s %s${NC}\n" "COMPTE" "EXPIRE" "ÉTAT" "CONNECTÉ DEPUIS"
  line
  local u exp st ct
  while read -r _ u exp; do
    [ -z "$u" ] && continue
    if passwd -S "$u" 2>/dev/null | awk '{exit !($2=="L")}'; then st="verrou"; else st="actif"; fi
    ct=$(_conn_time "$u")
    printf " %-16s %-12s %-8s %s\n" "$u" "${exp:-?}" "$st" "${ct:-—}"
  done < "$DB"
  pause
}

renew_account() {
  header; pick_user || return; user="$PICK"
  ask " Ajouter (jours) : " days; [[ "$days" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return; }
  out=$(nvpanel-cli renew "$user" "$days")
  echo "$out" | grep -q '^OK' && ok "$user prolongé (compteur quota remis à zéro)" || err "Échec : $out"
  pause
}

delete_account() {
  header; pick_user || return; user="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$user"; ask "" c
  confirm "$c" || { pause; return; }
  out=$(nvpanel-cli delete "$user")
  echo "$out" | grep -q '^OK' && ok "$user supprimé (connexion coupée)" || err "Échec : $out"
  pause
}


# Génère un compte de démonstration valable 24 h (identifiants aléatoires).
_rand_name(){ printf 'test%s' "$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c4)"; }
_rand_pass(){ tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c8; }

trial_account() {
  banner; center " 🎁  COMPTE TEST 24 H " "${BOLD}${WHT}"; line
  local n p
  n=$(_rand_name); p=$(_rand_pass)
  printf "   ${GRY}Génération d'un compte valable 24 heures…${NC}\n"
  create_account "$n" "$p" 1 1 0
}

lock_toggle() {
  header; pick_user || return; user="$PICK"
  if passwd -S "$user" 2>/dev/null | awk '{exit !($2=="L")}'; then
    nvpanel-cli unlock "$user" >/dev/null; ok "$user déverrouillé"
  else
    nvpanel-cli lock "$user" >/dev/null; ok "$user verrouillé (connexion coupée)"
  fi
  pause
}

view_account() {
  header; pick_user || return; user="$PICK"
  out=$(nvpanel-cli info "$user")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else
    err "Introuvable : $out"
  fi
  pause
}

slowdns_menu() {
  header
  if systemctl is-active --quiet nvpanel-slowdns; then
    ok "SlowDNS actif"
    printf "   NS  : ${WHT}%s${NC}\n" "$(cat /etc/nvpanel/slowdns/ns 2>/dev/null)"
    printf "   Pub : ${WHT}%s${NC}\n" "$(cat /etc/nvpanel/slowdns/server.pub 2>/dev/null)"
  else
    warn "SlowDNS non installé."
  fi
  echo; entry "1" "⬇️" "Installer / réinstaller"
  entry "2" "🗑️" "Désinstaller"
  entry "0" "⬅️" "Retour"; line
  ask "$(printf " ${WHT}➤ Choix :${NC} ")" s
  case "$s" in
    1) install-slowdns ;;
    2) uninstall_slowdns ;;
  esac
}

uninstall_slowdns() {
  banner; center " 🗑️  DÉSINSTALLER SLOWDNS " "${BOLD}${RED}"; line
  warn "SlowDNS sera retiré. Les comptes SSH ne sont pas touchés."
  printf "   ${RED}➤ Confirmer ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }
  systemctl disable --now nvpanel-slowdns >/dev/null 2>&1
  rm -f /etc/systemd/system/nvpanel-slowdns.service
  iptables -t nat -D PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null
  rm -rf /etc/nvpanel/slowdns
  systemctl daemon-reload >/dev/null 2>&1
  ok "SlowDNS a été désinstallé."; pause
}

udp_status() {
  header; center " 📡  UDP (UDPGW) " "${BOLD}${WHT}"; line
  local on=0
  for p in 7100 7200 7300; do
    if systemctl is-active --quiet nvpanel-badvpn-$p 2>/dev/null; then
      printf "   ${GRN}● actif  ${NC} UDPGW port %s\n" "$p"; on=$((on+1))
    else
      printf "   ${RED}○ arrêté ${NC} ${GRY}UDPGW port %s${NC}\n" "$p"
    fi
  done
  if systemctl is-active --quiet nvpanel-udp-custom 2>/dev/null; then
    printf "   ${GRN}● actif  ${NC} udp-custom (36712)\n"
  else
    printf "   ${GRY}– absent ${NC} ${GRY}udp-custom (facultatif)${NC}\n"
  fi
  echo
  local listen=0
  if command -v ss >/dev/null 2>&1; then
    ss -lnt 2>/dev/null | grep -q '127.0.0.1:7300' && listen=1
  elif command -v netstat >/dev/null 2>&1; then
    netstat -lnt 2>/dev/null | grep -q '127.0.0.1:7300' && listen=1
  fi
  if [ "$listen" = 1 ]; then
    printf "   ${GRN}✔ Port 7300 vérifié : l'UDP passe.${NC}\n\n"
    printf "   ${GRY}Dans l'appli client : UDPGW / Payload UDP =${NC} ${WHT}127.0.0.1:7300${NC}\n"
  elif [ "$on" -gt 0 ]; then
    warn "Services lancés mais le port 7300 ne répond pas — réinstalle (option 1)."
  else
    warn "UDP non installé — choisis 1 pour l'installer."
  fi
  echo; entry "1" "⬇️" "Installer / réinstaller"
  entry "2" "🗑️" "Désinstaller"
  entry "0" "⬅️" "Retour"; line
  ask "$(printf " ${WHT}➤ Choix :${NC} ")" s
  case "$s" in
    1) install-udp ;;
    2) uninstall_udp ;;
  esac
}

uninstall_udp() {
  banner; center " 🗑️  DÉSINSTALLER UDP " "${BOLD}${RED}"; line
  warn "Le module UDP sera retiré. Les comptes SSH ne sont pas touchés."
  printf "   ${RED}➤ Confirmer ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }
  for p in 7100 7200 7300; do
    systemctl disable --now nvpanel-badvpn-$p >/dev/null 2>&1
    rm -f /etc/systemd/system/nvpanel-badvpn-$p.service
  done
  systemctl disable --now nvpanel-udp-custom >/dev/null 2>&1
  rm -f /etc/systemd/system/nvpanel-udp-custom.service
  iptables -D INPUT -p udp --dport 36712 -j ACCEPT 2>/dev/null
  rm -rf /etc/nvpanel/udp
  systemctl daemon-reload >/dev/null 2>&1
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1
  ok "Le module UDP a été désinstallé."; pause
}

cleanup_menu() {
  while true; do
    banner; center " 🧹  NETTOYAGE DES COMPTES SSH " "${BOLD}${WHT}"; line
    local tot exp today c r out
    today=$(date +%F)
    tot=$(grep -c '^### ' "$DB" 2>/dev/null); tot=${tot:-0}
    exp=$(awk -v d="$today" '/^### /{ if ($3!="" && $3<d) c++ } END{print c+0}' "$DB" 2>/dev/null)
    printf "   ${GRY}Comptes au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les comptes expirés"
    entry "2" "💥" "Supprimer TOUS les comptes"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) [ "$exp" -eq 0 ] && { warn "Aucun compte expiré."; pause; continue; }
         printf "   ${YLW}Supprimer les %s compte(s) expiré(s) ? (o/n) : ${NC}" "$exp"; ask "" r
         confirm "$r" || continue
         out=$(nvpanel-cli purge ssh expired)
         ok "$(echo "$out" | awk '{print $2+0}') compte(s) supprimé(s)."; pause ;;
      2) [ "$tot" -eq 0 ] && { warn "Aucun compte."; pause; continue; }
         warn "Cela supprimera les $tot comptes SSH. Action irréversible."
         printf "   ${RED}➤ Confirmer la suppression totale ? (o/n) : ${NC}"; ask "" r
         confirm "$r" || { warn "Annulé."; pause; continue; }
         out=$(nvpanel-cli purge ssh all)
         ok "$(echo "$out" | awk '{print $2+0}') compte(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

while true; do
  header
  entry "1" "➕" "Créer un compte"
  entry "2" "📋" "Lister les comptes"
  entry "3" "🔍" "Revoir un compte"
  entry "4" "♻️" "Prolonger / réactiver"
  entry "5" "🔒" "Verrouiller / déverrouiller"
  entry "6" "🗑️" "Supprimer un compte"
  entry "7" "🌐" "SlowDNS"
  entry "8" "📡" "UDP (badvpn / udp-custom)"
  entry "9" "🧹" "Nettoyage des comptes"
  entry "10" "🎁" "Compte test 24 h"
  entry "0" "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}Choix :${NC} ")" o
  case "$o" in
    1) create_account ;; 2) list_accounts ;; 3) view_account ;;
    4) renew_account ;;  5) lock_toggle ;;   6) delete_account ;;
    7) slowdns_menu ;;   8) udp_status ;;    9) cleanup_menu ;;
    10) trial_account ;;
    0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
