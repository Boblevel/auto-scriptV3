#!/bin/bash
# ============================================================
#  nvpanel · limite d'appareils par compte (multi-login)
#  Tourne en boucle (service). Base : /etc/nvpanel/db/limit
#  Format d'une ligne :  utilisateur  nombre_max
# ============================================================
DB=/etc/nvpanel/db/limit
[ -f "$DB" ] || touch "$DB"

count_sessions() {
  # nombre de sessions sshd/dropbear ouvertes par l'utilisateur
  ps -eo user,comm | awk -v u="$1" '$1==u && ($2 ~ /sshd|dropbear/){c++} END{print c+0}'
}

while true; do
  while read -r user max; do
    [ -z "$user" ] && continue
    [[ "$max" =~ ^[0-9]+$ ]] || continue
    now=$(count_sessions "$user")
    if [ "$now" -gt "$max" ]; then
      # coupe les sessions excédentaires (les plus récentes d'abord)
      pids=$(ps -eo pid,user,comm --sort=-pid | awk -v u="$user" '$2==u && ($3 ~ /sshd|dropbear/){print $1}')
      excess=$(( now - max ))
      for pid in $pids; do
        [ "$excess" -le 0 ] && break
        kill -9 "$pid" 2>/dev/null && excess=$(( excess - 1 ))
      done
    fi
  done < "$DB"
  sleep 20
done
