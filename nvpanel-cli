#!/bin/bash
# ============================================================
#  nvpanel · CLI non-interactive (partagée : panel + bot)
#  Comptes SSH :
#    create <u> <p> <j> [lim] [Go] | renew <u> <j> | delete <u>
#    lock <u> | unlock <u> | list | status
#  Clients Xray/SS (proto = vmess|vless|trojan|ss) :
#    xadd <proto> <nom> <j> | xlist <proto> | xdel <proto> <nom>
#    xrenew <proto> <nom> <j>
# ============================================================
DB=/etc/nvpanel/db/ssh
LIMDB=/etc/nvpanel/db/limit
QDB=/etc/nvpanel/db/quota
XCONF=/usr/local/etc/xray/config.json
NDIR=/etc/nvpanel/xray
mkdir -p /etc/nvpanel/db; touch "$DB" "$LIMDB" "$QDB"

# ---- helpers Xray ------------------------------------------
xmeta() { # définit PORT PATHW TAG XDB pour un protocole
  case "$1" in
    vmess)  PORT=8080; PATHW="/vmess";  TAG="vmess-in";  XDB=/etc/nvpanel/db/vmess ;;
    vless)  PORT=8081; PATHW="/vless";  TAG="vless-in";  XDB=/etc/nvpanel/db/vless ;;
    trojan) PORT=8082; PATHW="/trojan"; TAG="trojan-in"; XDB=/etc/nvpanel/db/trojan ;;
    ss)     PORT=8388; PATHW="";        TAG="ss-in";     XDB=/etc/nvpanel/db/shadowsocks ;;
    *) return 1 ;;
  esac
}
xhost() { cat /etc/nvpanel/domain 2>/dev/null || cat /etc/nvpanel/ip 2>/dev/null; }
xtls()  { [ -f /etc/nvpanel/tls_on ] && echo 1 || echo 0; }

build_link() { # $1 proto  $2 nom  $3 id/clé
  local proto="$1" name="$2" id="$3" host tls penc
  host=$(xhost); tls=$(xtls); penc=$(printf '%s' "$PATHW" | jq -sRr @uri 2>/dev/null)
  case "$proto" in
    vmess)
      if [ "$tls" = 1 ]; then
        echo "vmess://$(printf '{"v":"2","ps":"%s","add":"%s","port":"443","id":"%s","aid":"0","scy":"auto","net":"ws","type":"none","host":"%s","path":"%s","tls":"tls","sni":"%s"}' "$name" "$host" "$id" "$host" "$PATHW" "$host" | base64 -w0)"
      else
        echo "vmess://$(printf '{"v":"2","ps":"%s","add":"%s","port":"%s","id":"%s","aid":"0","scy":"auto","net":"ws","type":"none","host":"","path":"%s","tls":"none"}' "$name" "$host" "$PORT" "$id" "$PATHW" | base64 -w0)"
      fi ;;
    vless)
      if [ "$tls" = 1 ]; then echo "vless://$id@$host:443?type=ws&security=tls&sni=$host&host=$host&path=$penc#$name"
      else echo "vless://$id@$host:$PORT?type=ws&security=none&path=$penc#$name"; fi ;;
    trojan)
      if [ "$tls" = 1 ]; then echo "trojan://$id@$host:443?type=ws&security=tls&sni=$host&host=$host&path=$penc#$name"
      else echo "trojan://$id@$host:$PORT?type=ws&security=none&path=$penc#$name"; fi ;;
    ss)
      local skey ui; skey=$(cat "$NDIR/ss_key" 2>/dev/null)
      ui=$(printf '%s' "2022-blake3-aes-256-gcm:$skey:$id" | base64 -w0)
      echo "ss://$ui@$host:$PORT#$name" ;;
  esac
}

cmd="$1"; shift 2>/dev/null

case "$cmd" in
  # ---------- SSH ----------
  create)
    user="$1"; pass="$2"; days="${3:-30}"; lim="${4:-2}"; gb="${5:-0}"
    { [ -z "$user" ] || [ -z "$pass" ]; } && { echo "ERR args"; exit 1; }
    id "$user" &>/dev/null && { echo "ERR exists"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || days=30
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    useradd -e "$exp" -s /bin/false -M "$user" &>/dev/null
    echo -e "$pass\n$pass" | passwd "$user" &>/dev/null
    echo "### $user $exp" >> "$DB"
    grep -q "^$user " "$LIMDB" && sed -i "s/^$user .*/$user $lim/" "$LIMDB" || echo "$user $lim" >> "$LIMDB"
    if [ "${gb:-0}" -gt 0 ] 2>/dev/null; then
      bytes=$(( gb * 1073741824 ))
      grep -q "^$user " "$QDB" && sed -i "s/^$user .*/$user $bytes/" "$QDB" || echo "$user $bytes" >> "$QDB"
      nvpanel-quota add "$user" 2>/dev/null
    fi
    echo "OK $user $exp" ;;
  renew)
    user="$1"; days="$2"
    id "$user" &>/dev/null || { echo "ERR nouser"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || { echo "ERR days"; exit 1; }
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    chage -E "$exp" "$user"; passwd -u "$user" &>/dev/null
    sed -i "s/^### $user .*/### $user $exp/" "$DB"
    sed -i "/^$user /d" /etc/nvpanel/db/quota_used 2>/dev/null
    echo "OK $user $exp" ;;
  delete)
    user="$1"; id "$user" &>/dev/null || { echo "ERR nouser"; exit 1; }
    userdel -f "$user" &>/dev/null
    sed -i "/^### $user /d" "$DB"
    sed -i "/^$user /d" "$LIMDB" "$QDB" /etc/nvpanel/db/quota_used 2>/dev/null
    echo "OK deleted" ;;
  lock)   id "$1" &>/dev/null && { passwd -l "$1" &>/dev/null; echo "OK locked"; } || echo "ERR nouser" ;;
  unlock) id "$1" &>/dev/null && { passwd -u "$1" &>/dev/null; echo "OK unlocked"; } || echo "ERR nouser" ;;
  list)
    awk -F: '$3>=1000 && $3<60000 {print $1}' /etc/passwd | while read -r u; do
      e=$(chage -l "$u" 2>/dev/null | awk -F: '/Account expires/{print $2}' | xargs)
      l=$(awk -v u="$u" '$1==u{print $2}' "$LIMDB"); l=${l:-0}
      q=$(awk -v u="$u" '$1==u{printf "%d",$2/1073741824}' "$QDB"); q=${q:-0}
      if passwd -S "$u" 2>/dev/null | grep -q ' L '; then s="verrou"; else s="actif"; fi
      echo "$u|${e:-jamais}|$l|$q|$s"
    done ;;
  status)
    . /etc/os-release 2>/dev/null
    echo "OS: ${PRETTY_NAME:-Linux}"
    echo "IP: $(cat /etc/nvpanel/ip 2>/dev/null)"
    echo "Domaine: $(cat /etc/nvpanel/domain 2>/dev/null || echo '-')"
    echo "TLS: $([ -f /etc/nvpanel/tls_on ] && echo actif || echo inactif)"
    echo "RAM: $(free -m | awk '/Mem:/{print $3"/"$2" Mo"}')"
    echo "Core: $(nproc)"
    echo "Uptime: $(uptime -p 2>/dev/null | sed 's/up //')"
    echo "Comptes SSH: $(awk -F: '$3>=1000 && $3<60000{c++} END{print c+0}' /etc/passwd)"
    echo "En ligne: $(ps -eo comm | grep -cE 'sshd|dropbear')" ;;

  # ---------- Xray / Shadowsocks ----------
  xadd)
    proto="$1"; name="$2"; days="${3:-30}"
    xmeta "$proto" || { echo "ERR proto"; exit 1; }
    [ -f "$XCONF" ] || { echo "ERR noxray"; exit 1; }
    touch "$XDB"; grep -q "^### $name " "$XDB" && { echo "ERR exists"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || days=30
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    if [ "$proto" = ss ]; then id=$(openssl rand -base64 32); client="{\"password\":\"$id\",\"email\":\"$name\"}"
    else
      id=$(cat /proc/sys/kernel/random/uuid)
      case "$proto" in
        vmess)  client="{\"id\":\"$id\",\"alterId\":0,\"email\":\"$name\"}" ;;
        vless)  client="{\"id\":\"$id\",\"email\":\"$name\"}" ;;
        trojan) client="{\"password\":\"$id\",\"email\":\"$name\"}" ;;
      esac
    fi
    jq "(.inbounds[]|select(.tag==\"$TAG\")|.settings.clients) += [$client]" "$XCONF" > "$XCONF.tmp" && mv "$XCONF.tmp" "$XCONF"
    echo "### $name $id $exp" >> "$XDB"
    systemctl restart xray >/dev/null 2>&1
    echo "OK $name $exp"
    build_link "$proto" "$name" "$id" ;;
  xlist)
    xmeta "$1" || { echo "ERR proto"; exit 1; }
    touch "$XDB"; awk '/^### /{print $2"|"$4}' "$XDB" ;;
  xdel)
    proto="$1"; name="$2"; xmeta "$proto" || { echo "ERR proto"; exit 1; }
    grep -q "^### $name " "$XDB" || { echo "ERR nouser"; exit 1; }
    jq "(.inbounds[]|select(.tag==\"$TAG\")|.settings.clients) |= map(select(.email!=\"$name\"))" "$XCONF" > "$XCONF.tmp" && mv "$XCONF.tmp" "$XCONF"
    sed -i "/^### $name /d" "$XDB"; systemctl restart xray >/dev/null 2>&1
    echo "OK deleted" ;;
  xrenew)
    proto="$1"; name="$2"; days="$3"; xmeta "$proto" || { echo "ERR proto"; exit 1; }
    grep -q "^### $name " "$XDB" || { echo "ERR nouser"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || { echo "ERR days"; exit 1; }
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    sed -i "s/^### $name \([^ ]*\) .*/### $name \1 $exp/" "$XDB"
    echo "OK $name $exp" ;;

  *) echo "usage: create|renew|delete|lock|unlock|list|status|xadd|xlist|xdel|xrenew"; exit 1 ;;
esac
