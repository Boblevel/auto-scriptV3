#!/bin/bash
# ============================================================
#  RHAFF SERVICE · CLI non-interactive (partagée : panel + bot)
#  SSH   : create|renew|delete|lock|unlock|list|status
#  Xray  : xadd <proto> <nom> <j> | xlist | xdel | xrenew  (proto=vmess|vless|trojan|ss)
#  create et xadd renvoient :  1re ligne "OK ..."  puis l'encadré du compte
# ============================================================
DB=/etc/nvpanel/db/ssh
LIMDB=/etc/nvpanel/db/limit
QDB=/etc/nvpanel/db/quota
META=/etc/nvpanel/db/ssh_meta   # user|pass|created|exp  (permet de reconsulter un compte)
XCONF=/usr/local/etc/xray/config.json
NDIR=/etc/nvpanel/xray
mkdir -p /etc/nvpanel/db; touch "$DB" "$LIMDB" "$QDB"

# ---- helpers -----------------------------------------------
_today(){ date +%Y-%m-%d; }
_ip(){ cat /etc/nvpanel/ip 2>/dev/null; }
_dom(){ cat /etc/nvpanel/domain 2>/dev/null; }
_host(){ local d; d=$(_dom); [ -n "$d" ] && printf '%s' "$d" || _ip; }
_xport(){ cat /etc/nvpanel/xport 2>/dev/null || echo 80; }
_sldnskey(){ cat /etc/nvpanel/slowdns/server.pub 2>/dev/null || echo "-"; }

xmeta() {
  case "$1" in
    vmess)  PORT=8080; PATHW="/vmess";  TAG="vmess-in";  XDB=/etc/nvpanel/db/vmess ;;
    vless)  PORT=8081; PATHW="/vless";  TAG="vless-in";  XDB=/etc/nvpanel/db/vless ;;
    trojan) PORT=8082; PATHW="/trojan"; TAG="trojan-in"; XDB=/etc/nvpanel/db/trojan ;;
    ss)     PORT=8388; PATHW="";        TAG="ss-in";     XDB=/etc/nvpanel/db/shadowsocks ;;
    *) return 1 ;;
  esac
}

# ---- encadré SSH -------------------------------------------
ssh_box(){ # user pass created exp
  local user="$1" pass="$2" cr="$3" ex="$4" ip dom ns key
  ip=$(_ip); dom=$(_dom); [ -z "$dom" ] && dom="$ip"
  if [ -n "$(_dom)" ]; then ns="ns-$(_dom)"; else ns="-"; fi
  key=$(_sldnskey)
  cat <<EOF
👨🏼‍💻 COMPTE PREMIUM SSH WEBSOCKET 👨🏼‍💻
==================================
👤 Username : $user
🔑 Password : $pass
📅 Created  : $cr
⏳ Expired  : $ex
========== 🌐 HOST-SSH ===========
🖥️ IP/Host  : $ip
🌐 Domain SSH : $dom
🧭 DNS       : 8.8.8.8
🛰️ Name Server(NS) : $ns
🔐 DNS PUBLIC KEY : $key
==================================
EOF
}

# ---- liens Xray --------------------------------------------
_vmess_link(){ # id host port path tls(0/1) name
  local id="$1" host="$2" port="$3" path="$4" tls="$5" name="$6" sec add
  if [ "$tls" = 1 ]; then
    printf 'vmess://%s' "$(printf '{"v":"2","ps":"XRAY_VMESS_%s","add":"%s","port":"%s","id":"%s","aid":"0","scy":"auto","net":"ws","type":"none","host":"%s","path":"%s","tls":"tls","sni":"%s"}' "$name" "$host" "$port" "$id" "$host" "$path" "$host" | base64 -w0)"
  else
    printf 'vmess://%s' "$(printf '{"v":"2","ps":"XRAY_VMESS_%s","add":"%s","port":"%s","id":"%s","aid":"0","scy":"auto","net":"ws","type":"none","host":"%s","path":"%s","tls":"none"}' "$name" "$host" "$port" "$id" "$host" "$path" | base64 -w0)"
  fi
}
_vless_link(){ # id host port path tls name
  if [ "$5" = 1 ]; then
    printf 'vless://%s@%s:%s?type=ws&encryption=none&security=tls&host=%s&path=%s&allowInsecure=1&sni=%s#XRAY_VLESS_%s' "$1" "$2" "$3" "$2" "$4" "$2" "$6"
  else
    printf 'vless://%s@%s:%s?type=ws&encryption=none&security=none&host=%s&path=%s#XRAY_VLESS_%s' "$1" "$2" "$3" "$2" "$4" "$6"
  fi
}
_trojan_link(){ # id host port path tls name
  if [ "$5" = 1 ]; then
    printf 'trojan://%s@%s:%s?type=ws&security=tls&host=%s&path=%s&allowInsecure=1&sni=%s#XRAY_TROJAN_%s' "$1" "$2" "$3" "$2" "$4" "$2" "$6"
  else
    printf 'trojan://%s@%s:%s?type=ws&security=none&host=%s&path=%s#XRAY_TROJAN_%s' "$1" "$2" "$3" "$2" "$4" "$6"
  fi
}

# ---- encadré Xray ------------------------------------------
xray_box(){ # proto name id created exp
  local proto="$1" name="$2" id="$3" cr="$4" ex="$5"
  local host path label ltls lnotls ip tlsp plainp
  host=$(_host); ip=$(_ip); tlsp=$(_xport); plainp=80
  case "$proto" in
    vmess)  path="/vmess";  label="VMESS";  ltls=$(_vmess_link "$id" "$host" "$tlsp" "$path" 1 "$name");  lnotls=$(_vmess_link "$id" "$host" "$plainp" "$path" 0 "$name") ;;
    vless)  path="/vless";  label="VLESS";  ltls=$(_vless_link "$id" "$host" "$tlsp" "$path" 1 "$name");  lnotls=$(_vless_link "$id" "$host" "$plainp" "$path" 0 "$name") ;;
    trojan) path="/trojan"; label="TROJAN"; ltls=$(_trojan_link "$id" "$host" "$tlsp" "$path" 1 "$name"); lnotls=$(_trojan_link "$id" "$host" "$plainp" "$path" 0 "$name") ;;
  esac
  cat <<EOF
========== 🟦 XRAY / $label ==========
📝 Remarks     : $name
🖥️ IP/Host     : $ip
🌐 Address     : $host
🔒 Port TLS    : $tlsp
🔓 Port No TLS : $plainp
🆔 User ID     : $id
🔐 Encryption  : none
🌐 Network     : ws
📁 Path        : $path
📅 Created     : $cr
⏳ Expired     : $ex
===================================
🔗 Link TLS    :
$ltls
🔗 Link No TLS :
$lnotls
===================================
EOF
}

# ---- encadré Shadowsocks -----------------------------------
ss_box(){ # name ckey created exp
  local name="$1" ck="$2" cr="$3" ex="$4" host skey ui link
  host=$(_host); skey=$(cat "$NDIR/ss_key" 2>/dev/null)
  ui=$(printf '%s' "2022-blake3-aes-256-gcm:$skey:$ck" | base64 -w0)
  link="ss://$ui@$host:8388#SS_$name"
  cat <<EOF
========== 🟩 SHADOWSOCKS ==========
📝 Remarks : $name
🌐 Address : $host
🔒 Port    : 8388
🧪 Method  : 2022-blake3-aes-256-gcm
📅 Created : $cr
⏳ Expired : $ex
===================================
🔗 Link :
$link
===================================
EOF
}

cmd="$1"; shift 2>/dev/null

case "$cmd" in
  # ---------- SSH ----------
  create)
    # nettoie les caractères invisibles (CR/LF/tab) que les claviers mobiles
    # peuvent glisser dans la saisie — cause fréquente d'échec d'auth
    user=$(printf '%s' "$1" | tr -d '\r\n\t ')
    pass=$(printf '%s' "$2" | tr -d '\r\n')
    days="${3:-30}"; lim="${4:-2}"; gb="${5:-0}"
    { [ -z "$user" ] || [ -z "$pass" ]; } && { echo "ERR args"; exit 1; }
    id "$user" &>/dev/null && { echo "ERR exists"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || days=30
    exp=$(date -d "+$days days" +"%Y-%m-%d"); cr=$(_today)
    useradd -e "$exp" -s /bin/false -M "$user" &>/dev/null
    # méthode identique au compte de test qui fonctionnait : on fournit le
    # mot de passe deux fois à passwd (printf = aucune interprétation d'échappement)
    printf '%s\n%s\n' "$pass" "$pass" | passwd "$user" &>/dev/null
    passwd -u "$user" &>/dev/null          # s'assure que le compte est déverrouillé
    chage -M 99999 "$user" &>/dev/null     # le mot de passe n'expire jamais
    echo "### $user $exp" >> "$DB"
    grep -q "^$user " "$LIMDB" && sed -i "s/^$user .*/$user $lim/" "$LIMDB" || echo "$user $lim" >> "$LIMDB"
    if [ "${gb:-0}" -gt 0 ] 2>/dev/null; then
      bytes=$(( gb * 1073741824 ))
      grep -q "^$user " "$QDB" && sed -i "s/^$user .*/$user $bytes/" "$QDB" || echo "$user $bytes" >> "$QDB"
      nvpanel-quota add "$user" 2>/dev/null
    fi
    echo "OK $user $exp"
    # mémorise les infos pour pouvoir reconsulter le compte plus tard
    touch "$META"; sed -i "/^$user|/d" "$META"; printf '%s|%s|%s|%s\n' "$user" "$pass" "$cr" "$exp" >> "$META"
    ssh_box "$user" "$pass" "$cr" "$exp" ;;
  renew)
    user=$(printf '%s' "$1" | tr -d '\r\n\t '); days="$2"
    id "$user" &>/dev/null || { echo "ERR nouser"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || { echo "ERR days"; exit 1; }
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    chage -E "$exp" "$user"; passwd -u "$user" &>/dev/null
    sed -i "s/^### $user .*/### $user $exp/" "$DB"
    sed -i "s/^\($user|[^|]*|[^|]*\)|.*/\1|$exp/" "$META" 2>/dev/null
    sed -i "/^$user /d" /etc/nvpanel/db/quota_used 2>/dev/null
    echo "OK $user $exp" ;;
  info)
    user=$(printf '%s' "$1" | tr -d '\r\n\t ')
    id "$user" &>/dev/null || { echo "ERR nouser"; exit 1; }
    line_meta=$(grep "^$user|" "$META" 2>/dev/null | head -1)
    if [ -n "$line_meta" ]; then
      IFS='|' read -r _ pass cr ex <<< "$line_meta"
    else
      pass="(inconnu — compte créé avant le suivi)"; cr="-"
      ex=$(awk -v u="$user" '$2==u{print $3}' "$DB")
    fi
    echo "OK $user"
    ssh_box "$user" "$pass" "$cr" "$ex" ;;
  delete)
    user=$(printf '%s' "$1" | tr -d '\r\n\t ')
    id "$user" &>/dev/null || { echo "ERR nouser"; exit 1; }
    pkill -KILL -u "$user" 2>/dev/null   # coupe immédiatement les sessions actives
    userdel -f "$user" &>/dev/null
    sed -i "/^### $user /d" "$DB"
    sed -i "/^$user|/d" "$META" 2>/dev/null
    sed -i "/^$user /d" "$LIMDB" "$QDB" /etc/nvpanel/db/quota_used 2>/dev/null
    echo "OK deleted" ;;
  lock)   u=$(printf '%s' "$1" | tr -d '\r\n\t '); id "$u" &>/dev/null && { passwd -l "$u" &>/dev/null; pkill -KILL -u "$u" 2>/dev/null; echo "OK locked"; } || echo "ERR nouser" ;;
  unlock) u=$(printf '%s' "$1" | tr -d '\r\n\t '); id "$u" &>/dev/null && { passwd -u "$u" &>/dev/null; echo "OK unlocked"; } || echo "ERR nouser" ;;
  list)
    awk -F: '$3>=1000 && $3<60000 {print $1}' /etc/passwd | while read -r u; do
      e=$(chage -l "$u" 2>/dev/null | awk -F: '/Account expires/{print $2}' | xargs)
      l=$(awk -v u="$u" '$1==u{print $2}' "$LIMDB"); l=${l:-0}
      q=$(awk -v u="$u" '$1==u{printf "%d",$2/1073741824}' "$QDB"); q=${q:-0}
      if passwd -S "$u" 2>/dev/null | awk '{exit !($2=="L")}'; then s="verrou"; else s="actif"; fi
      echo "$u|${e:-jamais}|$l|$q|$s"
    done ;;
  status)
    . /etc/os-release 2>/dev/null
    echo "OS: ${PRETTY_NAME:-Linux}"
    echo "IP: $(_ip)"
    echo "Domaine: $(_dom || echo '-')"
    echo "TLS: $([ -f /etc/nvpanel/tls_on ] && echo actif || echo inactif)"
    echo "RAM: $(free -m | awk '/Mem:/{print $3"/"$2" Mo"}')"
    echo "Core: $(nproc)"
    echo "Comptes SSH: $(grep -c '^### ' "$DB" 2>/dev/null)"
    echo "En ligne: $(ps -eo user,comm | awk '$2 ~ /sshd|dropbear/{print $1}' | sort -u | while read -r pu; do uid=$(id -u "$pu" 2>/dev/null); [ -n "$uid" ] && [ "$uid" -ge 1000 ] && [ "$uid" -lt 60000 ] && echo 1; done | wc -l)" ;;

  # ---------- Xray / Shadowsocks ----------
  xadd)
    proto="$1"; name=$(printf '%s' "$2" | tr -d '\r\n\t '); days="${3:-30}"
    xmeta "$proto" || { echo "ERR proto"; exit 1; }
    [ -f "$XCONF" ] || { echo "ERR noxray"; exit 1; }
    touch "$XDB"; grep -q "^### $name " "$XDB" && { echo "ERR exists"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || days=30
    exp=$(date -d "+$days days" +"%Y-%m-%d"); cr=$(_today)
    if [ "$proto" = ss ]; then id=$(openssl rand -base64 32); client="{\"password\":\"$id\",\"email\":\"$name\"}"
    else
      id=$(cat /proc/sys/kernel/random/uuid)
      case "$proto" in
        vmess)  client="{\"id\":\"$id\",\"alterId\":0,\"email\":\"$name\"}" ;;
        vless)  client="{\"id\":\"$id\",\"email\":\"$name\"}" ;;
        trojan) client="{\"password\":\"$id\",\"email\":\"$name\"}" ;;
      esac
    fi
    jq "(.inbounds[]|select(.tag==\"$TAG\")|.settings.clients) += [$client]" "$XCONF" > "$XCONF.tmp" && mv "$XCONF.tmp" "$XCONF"
    echo "### $name $id $exp" >> "$XDB"
    systemctl restart xray >/dev/null 2>&1
    echo "OK $name $exp"
    if [ "$proto" = ss ]; then ss_box "$name" "$id" "$cr" "$exp"; else xray_box "$proto" "$name" "$id" "$cr" "$exp"; fi ;;
  xlist)
    xmeta "$1" || { echo "ERR proto"; exit 1; }
    touch "$XDB"; awk '/^### /{print $2"|"$4}' "$XDB" ;;
  xdel)
    proto="$1"; name=$(printf '%s' "$2" | tr -d '\r\n\t '); xmeta "$proto" || { echo "ERR proto"; exit 1; }
    grep -q "^### $name " "$XDB" || { echo "ERR nouser"; exit 1; }
    jq "(.inbounds[]|select(.tag==\"$TAG\")|.settings.clients) |= map(select(.email!=\"$name\"))" "$XCONF" > "$XCONF.tmp" && mv "$XCONF.tmp" "$XCONF"
    sed -i "/^### $name /d" "$XDB"; systemctl restart xray >/dev/null 2>&1
    echo "OK deleted" ;;
  xrenew)
    proto="$1"; name=$(printf '%s' "$2" | tr -d '\r\n\t '); days="$3"; xmeta "$proto" || { echo "ERR proto"; exit 1; }
    grep -q "^### $name " "$XDB" || { echo "ERR nouser"; exit 1; }
    [[ "$days" =~ ^[0-9]+$ ]] || { echo "ERR days"; exit 1; }
    exp=$(date -d "+$days days" +"%Y-%m-%d")
    sed -i "s/^### $name \([^ ]*\) .*/### $name \1 $exp/" "$XDB"
    echo "OK $name $exp" ;;
  xinfo)
    proto="$1"; name=$(printf '%s' "$2" | tr -d '\r\n\t '); xmeta "$proto" || { echo "ERR proto"; exit 1; }
    row=$(grep "^### $name " "$XDB" 2>/dev/null | head -1)
    [ -z "$row" ] && { echo "ERR nouser"; exit 1; }
    id=$(echo "$row" | awk '{print $3}'); exp=$(echo "$row" | awk '{print $4}')
    echo "OK $name"
    if [ "$proto" = ss ]; then ss_box "$name" "$id" "-" "$exp"; else xray_box "$proto" "$name" "$id" "-" "$exp"; fi ;;

  *) echo "usage: create|renew|delete|lock|unlock|list|status|info|xadd|xlist|xdel|xrenew|xinfo"; exit 1 ;;
esac
