#!/bin/bash
# ============================================================
#  nvpanel · quota de données par compte
#
#  Comptabilise le trafic servi à chaque compte (règles iptables
#  « owner » par UID) et verrouille le compte au dépassement.
#
#  Base quota : /etc/nvpanel/db/quota       →  utilisateur  octets_max
#  Compteur   : /etc/nvpanel/db/quota_used  →  utilisateur  octets_consommés
#
#  IMPORTANT : à chaque passage, on lit les compteurs PUIS on les
#  remet à zéro (-Z). On additionne donc uniquement ce qui a été
#  consommé depuis le passage précédent. Sans cette remise à zéro,
#  le compteur cumulatif était ré-additionné à chaque cron et le
#  quota était atteint bien trop tôt.
# ============================================================
QDB=/etc/nvpanel/db/quota
USED=/etc/nvpanel/db/quota_used
mkdir -p /etc/nvpanel/db; touch "$QDB" "$USED"
CHAIN=NVPANEL_QUOTA

action="$1"

ensure_chain() {
  iptables -L "$CHAIN" -n >/dev/null 2>&1 || {
    iptables -N "$CHAIN" 2>/dev/null
    iptables -C OUTPUT -j "$CHAIN" 2>/dev/null || iptables -I OUTPUT -j "$CHAIN" 2>/dev/null
  }
}

# add <user> : crée la règle de comptage pour l'UID du compte
if [ "$action" = "add" ]; then
  ensure_chain
  uid=$(id -u "$2" 2>/dev/null) || exit 0
  iptables -C "$CHAIN" -m owner --uid-owner "$uid" -j RETURN 2>/dev/null || \
    iptables -A "$CHAIN" -m owner --uid-owner "$uid" -j RETURN 2>/dev/null
  exit 0
fi

# reset <user> : remet le compteur du compte à zéro
if [ "$action" = "reset" ]; then
  [ -n "$2" ] && sed -i "/^$2 /d" "$USED" 2>/dev/null
  exit 0
fi

# ---- check (appelé par cron) --------------------------------
ensure_chain

# 1) On relève tous les compteurs d'un coup, PUIS on les remet à zéro.
SNAP=$(iptables -L "$CHAIN" -vxn 2>/dev/null | awk '
  /owner UID match/ {
    for (i = 1; i <= NF; i++) if ($i == "match") { print $(i+1), $2; break }
  }')
iptables -Z "$CHAIN" >/dev/null 2>&1

# 2) On ajoute le delta de chaque compte à son total cumulé.
while read -r user max; do
  [ -z "$user" ] && continue
  [ -z "$max" ] && continue
  uid=$(id -u "$user" 2>/dev/null) || continue

  delta=$(printf '%s\n' "$SNAP" | awk -v id="$uid" '$1==id {print $2; exit}')
  delta=${delta:-0}

  prev=$(awk -v u="$user" '$1==u {print $2; exit}' "$USED" 2>/dev/null)
  prev=${prev:-0}
  total=$(( prev + delta ))

  if grep -q "^$user " "$USED" 2>/dev/null; then
    sed -i "s/^$user .*/$user $total/" "$USED"
  else
    echo "$user $total" >> "$USED"
  fi

  # 3) Verrouillage au dépassement (0 = illimité).
  if [ "$max" -gt 0 ] 2>/dev/null && [ "$total" -ge "$max" ] 2>/dev/null; then
    passwd -l "$user" >/dev/null 2>&1
    pkill -KILL -u "$user" 2>/dev/null
  fi
done < <(awk 'NF {print $1, $2}' "$QDB")
exit 0
