#!/bin/bash
# ============================================================
#  nvpanel · configuration du bot Telegram   (commande : menu-bot)
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
CONF=/etc/nvpanel/bot.conf

banner; center " BOT TELEGRAM " "${BOLD}${WHT}"; line

if [ -f "$CONF" ]; then
  printf " ${GRY}Bot déjà configuré. Statut : ${NC}"
  systemctl is-active --quiet nvpanel-bot && printf "${GRN}actif${NC}\n" || printf "${RED}arrêté${NC}\n"
  echo
fi

entry "1" "🔧" "Configurer / reconfigurer le bot"
entry "2" "▶️" "Démarrer le bot"
entry "3" "⏹️" "Arrêter le bot"
entry "4" "📄" "Voir le statut / logs"
entry "0" "⬅️" "Retour"
line
read -rp "$(printf " ${WHT}Choix :${NC} ")" o

case "$o" in
  1)
    echo
    printf " ${GRY}1) Crée un bot via @BotFather et copie le TOKEN.${NC}\n"
    printf " ${GRY}2) Récupère ton ID via @userinfobot.${NC}\n\n"
    read -rp " TOKEN BotFather : " token
    read -rp " Ton ID Telegram : " adminid
    [ -z "$token" ] || [ -z "$adminid" ] && { err "Token et ID requis"; pause; exit 1; }
    cat > "$CONF" <<EOF
TOKEN=$token
ADMIN=$adminid
EOF
    chmod 600 "$CONF"

    # service
    cat > /etc/systemd/system/nvpanel-bot.service <<EOF
[Unit]
Description=nvpanel bot Telegram
After=network.target
[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/nvpanel-bot
Restart=always
[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable --now nvpanel-bot >/dev/null 2>&1
    sleep 2
    if systemctl is-active --quiet nvpanel-bot; then
      ok "Bot activé ! Ouvre Telegram et tape /start"
    else
      err "Le bot n'a pas démarré. Vérifie avec : journalctl -u nvpanel-bot -n 20"
    fi
    pause ;;
  2) systemctl start nvpanel-bot && ok "Démarré"; pause ;;
  3) systemctl stop nvpanel-bot && ok "Arrêté"; pause ;;
  4) systemctl status nvpanel-bot --no-pager -l | head -n 15; pause ;;
  0) exit 0 ;;
  *) warn "Invalide"; sleep 1 ;;
esac
