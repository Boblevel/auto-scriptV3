#!/bin/bash
# ============================================================
#  nvpanel · configuration du bot Telegram   (commande : menu-bot)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
CONF=/etc/nvpanel/bot.conf

banner; center " BOT TELEGRAM " "${BOLD}${WHT}"; line

if [ -f "$CONF" ]; then
  printf " ${GRY}Bot déjà configuré. Statut : ${NC}"
  systemctl is-active --quiet nvpanel-bot && printf "${GRN}actif${NC}\n" || printf "${RED}arrêté${NC}\n"
  # Le bot n'est jamais redémarré automatiquement (ni par la mise à jour).
  # Si le fichier du bot est plus récent que le processus en cours,
  # c'est qu'une nouvelle version attend un redémarrage manuel.
  if systemctl is-active --quiet nvpanel-bot 2>/dev/null; then
    _started=$(systemctl show -p ActiveEnterTimestampMonotonic --value nvpanel-bot 2>/dev/null)
    _now=$(awk '{printf "%d", $1*1000000}' /proc/uptime 2>/dev/null)
    _fmtime=$(stat -c %Y /usr/local/bin/nvpanel-bot 2>/dev/null)
    _boot=$(date +%s); _boot=$(( _boot - $(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null) ))
    if [ -n "$_started" ] && [ -n "$_fmtime" ] && [ "$_started" -gt 0 ] 2>/dev/null; then
      _startepoch=$(( _boot + _started/1000000 ))
      if [ "$_fmtime" -gt "$_startepoch" ] 2>/dev/null; then
        printf " ${YLW}⚠ Nouvelle version installée — choisis 2 pour l'appliquer.${NC}\n"
      fi
    fi
  fi
  echo
fi

entry "1" "🔧" "Configurer le bot"
entry "2" "🔁" "Redémarrer le bot"
entry "3" "⏹️" "Arrêter le bot"
entry "4" "📄" "Voir le statut / logs"
entry "0" "⬅️" "Retour"
line
read -rp "$(printf " ${WHT}Choix :${NC} ")" o

case "$o" in
  1)
    echo
    printf " ${GRY}1) Crée un bot via @BotFather et copie le TOKEN.${NC}\n"
    printf " ${GRY}2) Récupère ton ID via @userinfobot.${NC}\n\n"
    read -rp " TOKEN BotFather : " token
    read -rp " Ton ID Telegram : " adminid
    [ -z "$token" ] || [ -z "$adminid" ] && { err "Token et ID requis"; pause; exit 1; }
    cat > "$CONF" <<EOF
TOKEN=$token
ADMIN=$adminid
EOF
    chmod 600 "$CONF"

    # service
    cat > /etc/systemd/system/nvpanel-bot.service <<EOF
[Unit]
Description=nvpanel bot Telegram
After=network.target
[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/nvpanel-bot
Restart=always
[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable --now nvpanel-bot >/dev/null 2>&1
    sleep 2
    if systemctl is-active --quiet nvpanel-bot; then
      ok "Bot activé ! Ouvre Telegram et tape /start"
    else
      err "Le bot n'a pas démarré. Vérifie avec : journalctl -u nvpanel-bot -n 20"
    fi
    pause ;;
  2) systemctl restart nvpanel-bot >/dev/null 2>&1 && ok "Bot redémarré" || err "Échec du redémarrage"; pause ;;
  3) systemctl stop nvpanel-bot && ok "Arrêté"; pause ;;
  4) systemctl status nvpanel-bot --no-pager -l | head -n 15; pause ;;
  0) exit 0 ;;
  *) warn "Invalide"; sleep 1 ;;
esac
