#!/bin/bash
# ============================================================
#  RHAFF SERVICE · menu principal   (commandes : menu / acc / dgh)
# ============================================================
source /etc/nvpanel/lib/ui.sh

run() {
  if command -v "$1" >/dev/null 2>&1; then "$@"
  else clear; banner; warn "Module « $1 » en préparation (bientôt disponible)."; pause; fi
}

services_status() {
  banner; center " 📊  STATUT DES SERVICES " "${BOLD}${WHT}"; line
  for s in ssh dropbear xray nginx wg-quick@wg0 nvpanel-slowdns nvpanel-badvpn-7300 nvpanel-limit nvpanel-bot; do
    if systemctl is-active --quiet "$s" 2>/dev/null; then
      printf "  ${GRN}●${NC} %s\n" "$s"
    else
      printf "  ${RED}○${NC} %s\n" "$s"
    fi
  done
  pause
}

reboot_server() {
  banner; center " 🔁  REDÉMARRAGE DU SERVEUR " "${BOLD}${WHT}"; line
  warn "Le serveur va redémarrer. Ta session SSH sera coupée quelques instants."
  read -rp " Confirmer le redémarrage ? (o/n) : " r
  if confirm "$r"; then
    printf "${YLW}Redémarrage en cours…${NC}\n"; sleep 1; reboot
  fi
}

optimize_server() {
  banner; center " 🚀  OPTIMISATION DU SERVEUR " "${BOLD}${WHT}"; line
  printf "   ${GRY}Nettoyage sûr (n'affecte ni les comptes ni la config)…${NC}\n\n"
  local ram_b disk_b ram_a disk_a rf df_
  ram_b=$(free -m | awk '/Mem:/{print $3}')
  disk_b=$(df -m / | awk 'NR==2{print $3}')
  printf "   ${CYN}➜${NC} Paquets inutiles et cache APT…\n"
  export DEBIAN_FRONTEND=noninteractive
  apt-get -y autoremove --purge >/dev/null 2>&1
  apt-get -y clean >/dev/null 2>&1
  apt-get -y autoclean >/dev/null 2>&1
  printf "   ${CYN}➜${NC} Rotation des journaux système…\n"
  journalctl --vacuum-time=3d >/dev/null 2>&1
  journalctl --vacuum-size=50M >/dev/null 2>&1
  find /var/log -type f \( -name "*.gz" -o -name "*.[0-9]" -o -name "*.old" \) -delete 2>/dev/null
  find /var/log -type f -name "*.log" -size +20M -exec truncate -s 0 {} \; 2>/dev/null
  printf "   ${CYN}➜${NC} Fichiers temporaires…\n"
  find /tmp -type f -atime +2 -delete 2>/dev/null
  rm -rf /var/tmp/* 2>/dev/null
  rm -rf /root/.cache/* 2>/dev/null
  printf "   ${CYN}➜${NC} Libération de la mémoire (caches)…\n"
  sync; echo 3 > /proc/sys/vm/drop_caches 2>/dev/null
  ram_a=$(free -m | awk '/Mem:/{print $3}')
  disk_a=$(df -m / | awk 'NR==2{print $3}')
  rf=$(( ram_b - ram_a ));  [ "$rf" -lt 0 ] && rf=0
  df_=$(( disk_b - disk_a )); [ "$df_" -lt 0 ] && df_=0
  echo; ok "Serveur optimisé et nettoyé."
  printf "   ${GRY}RAM libérée   :${NC} ${WHT}%s Mo${NC}  ${GRY}(%s → %s Mo utilisés)${NC}\n" "$rf" "$ram_b" "$ram_a"
  printf "   ${GRY}Disque libéré :${NC} ${WHT}%s Mo${NC}  ${GRY}(%s → %s Mo utilisés)${NC}\n" "$df_" "$disk_b" "$disk_a"
  pause
}

while true; do
  banner
  sysinfo
  line
  stats
  line
  entry "01" "🔒" "SSH · SlowDNS · UDP"
  entry "02" "🟣" "Vmess  (Xray)"
  entry "03" "🔵" "Vless  (Xray)"
  entry "04" "🟠" "Trojan (Xray)"
  entry "05" "🟢" "Shadowsocks"
  entry "06" "🛡️" "WireGuard"
  entry "07" "🌐" "L2TP"
  entry "08" "📡" "PPTP"
  entry "09" "🔐" "SSTP"
  line
  entry "10" "🤖" "Bot Telegram"
  entry "11" "📈" "Statut des services"
  entry "12" "⚙️" "Paramètres"
  entry "13" "🔁" "Redémarrer le serveur"
  entry "14" "🔄" "Mettre à jour"
  entry "15" "🚀" "Optimiser le serveur"
  entry "16" "🗑️" "Désinstaller le script"
  entry "00" "🚪" "Quitter"
  line
  read -rp "$(printf " ${WHT}➤ Choix :${NC} ")" opt
  case "$opt" in
    01|1) run menu-ssh ;;
    02|2) run menu-xray vmess ;;
    03|3) run menu-xray vless ;;
    04|4) run menu-xray trojan ;;
    05|5) run menu-ss ;;
    06|6) run menu-wg ;;
    07|7) run menu-l2tp ;;
    08|8) run menu-pptp ;;
    09|9) run menu-sstp ;;
    10)   run menu-bot ;;
    11)   services_status ;;
    12)   run menu-settings ;;
    13)   reboot_server ;;
    14)   run update ;;
    15)   optimize_server ;;
    16)   run menu-uninstall ;;
    00|0) clear; exit 0 ;;
    *)    warn "Option invalide"; sleep 1 ;;
  esac
done
