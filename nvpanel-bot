import json, subprocess, urllib.request, urllib.parse, time

CONF = "/etc/nvpanel/bot.conf"

def load_conf():
    c = {}
    with open(CONF) as f:
        for ln in f:
            ln = ln.strip()
            if "=" in ln and not ln.startswith("#"):
                k, v = ln.split("=", 1); c[k.strip()] = v.strip()
    return c

conf = load_conf()
TOKEN = conf.get("TOKEN", ""); ADMIN = str(conf.get("ADMIN", ""))
API = "https://api.telegram.org/bot%s/" % TOKEN
STATE = {}

def api(method, **params):
    data = urllib.parse.urlencode(
        {k: (json.dumps(v) if isinstance(v, (dict, list)) else v) for k, v in params.items()}
    ).encode()
    try:
        with urllib.request.urlopen(API + method, data=data, timeout=60) as r:
            return json.load(r)
    except Exception:
        return {}

def esc(t):
    """Échappe les caractères réservés par le HTML de Telegram."""
    return (str(t).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;"))

def cli(*args):
    try:
        return subprocess.run(["nvpanel-cli", *args], capture_output=True, text=True, timeout=40).stdout.strip()
    except Exception as e:
        return "ERR %s" % e

def read_file(p):
    try:
        with open(p) as f: return f.read().strip()
    except Exception:
        return ""

def count_db(name):
    try:
        with open("/etc/nvpanel/db/" + name) as f:
            return sum(1 for l in f if l.startswith("### "))
    except Exception:
        return 0

def sys_info():
    up = ram = load = "?"
    try:
        s = float(read_file("/proc/uptime").split()[0])
        d = int(s // 86400); h = int((s % 86400) // 3600); m = int((s % 3600) // 60)
        up = ("%dj %dh %dm" % (d, h, m)) if d else ("%dh %dm" % (h, m))
    except Exception:
        pass
    try:
        mem = {}
        for ln in open("/proc/meminfo"):
            k, v = ln.split(":"); mem[k] = int(v.strip().split()[0])
        tot = mem["MemTotal"] // 1024; avail = mem.get("MemAvailable", 0) // 1024
        ram = "%d/%d Mo" % (tot - avail, tot)
    except Exception:
        pass
    try:
        load = " ".join(read_file("/proc/loadavg").split()[:3])
    except Exception:
        pass
    return up, ram, load

def sh(cmd):
    try:
        return subprocess.run(["bash", "-c", cmd], capture_output=True, text=True, timeout=15).stdout.strip()
    except Exception:
        return ""

def _int(s):
    try:
        return int(str(s).strip())
    except Exception:
        return 0

def ssh_online():
    return _int(sh("ps -eo user,comm | awk '$2 ~ /sshd|dropbear/{print $1}' | sort -u | "
                   "while read u; do i=$(id -u \"$u\" 2>/dev/null); "
                   "[ -n \"$i\" ] && [ \"$i\" -ge 1000 ] && [ \"$i\" -lt 60000 ] && echo 1; done | wc -l"))

def ssh_blocked():
    return _int(sh("c=0; while read _ u _; do [ -z \"$u\" ] && continue; "
                   "s=$(passwd -S \"$u\" 2>/dev/null | awk '{print $2}'); "
                   "[ \"$s\" = L ] && c=$((c+1)); done < /etc/nvpanel/db/ssh 2>/dev/null; echo $c"))

def port_online(p):
    return _int(sh("ss -tnH state established '( sport = :%s )' 2>/dev/null | wc -l" % p))

def wg_online():
    return _int(sh("wg show wg0 latest-handshakes 2>/dev/null | "
                   "awk -v n=$(date +%s) '$2>0 && (n-$2)<180{c++} END{print c+0}'"))

