def do_list(chat):
    out = cli("list")
    if not out:
        send(chat, "Aucun compte SSH."); return
    lines = ["<b>Comptes SSH</b>", "<code>user        expire     dev quota etat</code>"]
    for l in out.splitlines():
        p = l.split("|")
        if len(p) == 5:
            lines.append("<code>%-11s %-10s %-3s %-5s %s</code>" % (p[0][:11], p[1], p[2], p[3]+"G", p[4]))
    send(chat, "\n".join(lines))

def do_xlist(chat, proto):
    out = cli("xlist", proto)
    if not out or out.startswith("ERR"):
        send(chat, "Aucun client %s." % proto, kb=proto_kb(proto)); return
    lines = ["<b>Clients %s</b>" % proto]
    for l in out.splitlines():
        n, _, e = l.partition("|")
        lines.append("<code>%-16s %s</code>" % (n, e))
    send(chat, "\n".join(lines), kb=proto_kb(proto))

def handle_callback(chat, data):
    if data == "menu":
        STATE.pop(chat, None); show_menu(chat); return
    if data == "cancel":
        STATE.pop(chat, None)
        send(chat, "\u274C Action annul\u00e9e.")
        return
    if data == "monitor":
        do_monitor(chat); return
    if data == "trial":
        send(chat, "<b>\U0001F381 Compte test 24 h</b>\nChoisis le protocole :", kb=trial_kb()); return
    if data == "purge":
        send(chat, "<b>\U0001F9F9 Purger les comptes expir\u00e9s</b>\nChoisis le protocole :", kb=purge_kb()); return
    if data.startswith("t:"):
        p = data[2:]
        if p == "ssh":
            n, pw = rand_name(), rand_pass()
            out = cli("create", n, pw, "1", "1", "0")
        elif p in ("l2tp", "pptp", "sstp"):
            n, pw = rand_name(), rand_pass()
            out = ppp("add", p, n, pw, "1")
        else:
            out = cli("xadd", p, rand_name(), "1")
        if out.startswith("OK"):
            send(chat, "<b>\u2705 Compte test 24 h cr\u00e9\u00e9</b>\n<pre>%s</pre>" % esc("\n".join(out.split("\n")[1:])))
        else:
            send(chat, "\u274C \u00c9chec : <code>%s</code>" % esc(out))
        return
    if data.startswith("g:"):
        p = data[2:]
        out = ppp("purge", p, "expired") if p in ("l2tp", "pptp", "sstp") else cli("purge", p, "expired")
        n = out.split()[1] if out.startswith("OK") and len(out.split()) > 1 else "0"
        send(chat, "\U0001F9F9 <b>%s</b> : %s compte(s) expir\u00e9(s) supprim\u00e9(s)." % (p.upper(), n)); return
    if data.startswith("pp:"):
        p = data[3:]
        send(chat, "<b>%s</b> \u2014 choisis :" % p.upper(), kb=ppp_kb(p)); return
    if data.startswith("pl2:"):
        p = data[4:]
        rows = ppp("list", p)
        txt = "\n".join("%-16s %s" % tuple(r.split("|")[:2]) for r in rows.split("\n") if "|" in r)
        send(chat, "<b>\U0001F4CB %s</b>\n<pre>%s</pre>" % (p.upper(), esc(txt or "aucun compte"))); return
    if data.startswith("pa2:"):
        STATE[chat] = {"action": "pppadd", "proto": data[4:]}
        send(chat, "Envoie : <code>utilisateur motdepasse jours</code>", kb=cancel_kb()); return
    if data.startswith("pd2:"):
        STATE[chat] = {"action": "pppdel", "proto": data[4:]}
        send(chat, "Envoie le <b>nom</b> du compte \u00e0 supprimer :", kb=cancel_kb()); return
    if data.startswith("wg:"):
        try:
            with open("/etc/nvpanel/db/wireguard") as f:
                rows = [l.split() for l in f if l.startswith("### ")]
            txt = "\n".join("%-16s %-14s %s" % (r[1], r[3], r[4]) for r in rows if len(r) > 4)
        except Exception:
            txt = ""
        send(chat, "<b>\U0001F6E1 WireGuard</b>\n<pre>%s</pre>" % esc(txt or "aucun client")); return
    if data == "list":
        do_list(chat); return
    if data == "status":
        send(chat, "<b>\U0001F5A5 \u00c9tat du serveur</b>\n<code>%s</code>" % cli("status")); return
    if data.startswith("p:"):
        p = data[2:]; send(chat, "<b>%s</b> - choisis :" % p.upper(), kb=proto_kb(p)); return
    if data.startswith("pl:"):
        do_xlist(chat, data[3:]); return
    if data.startswith("pa:"):
        STATE[chat] = {"action": "xadd", "proto": data[3:]}
        send(chat, "Envoie : <code>nom jours</code>  (ex : <code>client1 30</code>)", kb=cancel_kb()); return
    if data.startswith("pd:"):
        STATE[chat] = {"action": "xdel", "proto": data[3:]}
        send(chat, "Envoie le <b>nom</b> du client \u00e0 supprimer :", kb=cancel_kb()); return
    prompts = {
        "create": "Nouveau compte SSH.\n<code>user motdepasse jours [limite] [quotaGo]</code>\nex : <code>client1 pass123 30 2 50</code>",
        "delete": "Nom du compte SSH \u00e0 supprimer :",
        "lock":   "Nom du compte \u00e0 verrouiller :",
        "unlock": "Nom du compte \u00e0 d\u00e9verrouiller :",
        "renew":  "Envoie : <code>user jours</code>",
    }
    if data in prompts:
        STATE[chat] = {"action": data}
        send(chat, prompts[data], kb=cancel_kb())

def handle_text(chat, text):
    st = STATE.pop(chat, None)
    if not st:
        show_menu(chat); return
    a = st["action"]; parts = text.split()
    if a == "create":
        if len(parts) < 3: send(chat, "Format : user motdepasse jours [limite] [quotaGo]"); return
        r = cli("create", *parts[:5])
        if r.startswith("OK"):
            box = "\n".join(r.splitlines()[1:])
            send(chat, "\u2705 Compte SSH cree\n<code>%s</code>" % box)
        else:
            send(chat, "\u274C %s" % r)
    elif a == "renew":
        if len(parts) < 2: send(chat, "Format : user jours"); return
        r = cli("renew", parts[0], parts[1])
        send(chat, ("\u2705 %s" % r) if r.startswith("OK") else ("\u274C %s" % r))
    elif a in ("delete", "lock", "unlock"):
        r = cli(a, parts[0]); send(chat, ("\u2705 %s" % r) if r.startswith("OK") else ("\u274C %s" % r))
    elif a == "pppadd":
        p = st["proto"]
        if len(parts) < 2:
            send(chat, "Format : utilisateur motdepasse jours"); return
        days = parts[2] if len(parts) > 2 else "30"
        r = ppp("add", p, parts[0], parts[1], days)
        if r.startswith("OK"):
            send(chat, "\u2705 Compte %s cr\u00e9\u00e9\n<pre>%s</pre>" % (p.upper(), esc("\n".join(r.splitlines()[1:]))))
        else:
            send(chat, "\u274C %s" % esc(r))
    elif a == "pppdel":
        r = ppp("del", st["proto"], parts[0])
        send(chat, ("\u2705 %s supprim\u00e9" % parts[0]) if r.startswith("OK") else ("\u274C %s" % esc(r)))
    elif a == "xadd":
        proto = st["proto"]
        if len(parts) < 1: send(chat, "Format : nom jours"); return
        days = parts[1] if len(parts) > 1 else "30"
        out = cli("xadd", proto, parts[0], days)
        first = out.splitlines()[0] if out else "ERR"
        if first.startswith("OK"):
            box = "\n".join(out.splitlines()[1:])
            send(chat, "\u2705 %s cree\n<code>%s</code>" % (proto, box))
        else:
            send(chat, "\u274C %s" % first)
    elif a == "xdel":
        r = cli("xdel", st["proto"], parts[0])
        send(chat, "\u2705 Supprime" if r.startswith("OK") else ("\u274C %s" % r))

def authorized(uid):
    return str(uid) == ADMIN

def main():
    offset = None
    if ADMIN:
        api("sendMessage", chat_id=ADMIN, text="\U0001F916 nvpanel bot en ligne", reply_markup=main_kb())
    while True:
        upd = api("getUpdates", offset=offset, timeout=50)
        if not upd.get("ok"):
            time.sleep(3); continue
        for u in upd["result"]:
            offset = u["update_id"] + 1
            if "callback_query" in u:
                cq = u["callback_query"]; uid = cq["from"]["id"]; chat = cq["message"]["chat"]["id"]
                api("answerCallbackQuery", callback_query_id=cq["id"])
                if not authorized(uid): api("sendMessage", chat_id=chat, text="\u26D4 Non autorise"); continue
                handle_callback(chat, cq["data"])
            elif "message" in u:
                m = u["message"]; uid = m["from"]["id"]; chat = m["chat"]["id"]
                if not authorized(uid): api("sendMessage", chat_id=chat, text="\u26D4 Non autorise"); continue
                txt = m.get("text", "")
                if txt in ("/start", "/menu"): show_menu(chat)
                else: handle_text(chat, txt)

if __name__ == "__main__":
    if not TOKEN or not ADMIN:
        raise SystemExit("bot.conf incomplet (TOKEN / ADMIN)")
    while True:
        try: main()
        except Exception: time.sleep(5)
