def rand_name():
    import random, string
    return "test" + "".join(random.choice(string.ascii_lowercase + string.digits) for _ in range(4))

def rand_pass():
    import random, string
    return "".join(random.choice(string.ascii_letters + string.digits) for _ in range(8))

def ppp(*args):
    try:
        return subprocess.run(["nvpanel-ppp", *args], capture_output=True, text=True, timeout=40).stdout.strip()
    except Exception as e:
        return "ERR %s" % e

def cancel_kb():
    return {"inline_keyboard": [[{"text": "\u274C Annuler / Retour", "callback_data": "cancel"}]]}

def send(chat, text, kb=None):
    mk = kb if kb is not None else main_kb()
    api("sendMessage", chat_id=chat, text=text, parse_mode="HTML", reply_markup=mk)

