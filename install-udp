#!/bin/bash
# ============================================================
#  RHAFF SERVICE · installation UDP   (commande : install-udp)
#
#  badvpn-udpgw (UDPGW 7100/7200/7300) installé en 3 essais successifs :
#    a) paquet de la distribution (rapide, mais absent sur beaucoup de VPS)
#    b) binaire hébergé dans ton dépôt GitHub (si tu en fournis un)
#    c) compilation depuis la source officielle  ← méthode qui marche partout
#  Puis VÉRIFICATION réelle que le port 7300 écoute.
#
#  udp-custom : optionnel, nécessite un binaire hébergé.
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }

REPO_RAW="https://raw.githubusercontent.com/Boblevel/auto-scriptV3/main"
DIR=/etc/nvpanel/udp
mkdir -p "$DIR"
AUTO=0; [ "$1" = "auto" ] && AUTO=1


case "$(uname -m)" in
  aarch64|arm64) UDPC_SRC="udp-custom-arm64" ;;
  *)             UDPC_SRC="udp-custom" ;;
esac

# vrai binaire exécutable ? (évite qu'une page « 404 » soit prise pour un binaire)
is_bin(){
  [ -s "$1" ] || return 1
  local sig; sig=$(head -c 4 "$1" 2>/dev/null | od -An -tx1 2>/dev/null | tr -d ' \n')
  [ "$sig" = "7f454c46" ]
}

# ---------- mode « build » : fabriquer le binaire à héberger ----------
# Usage : install-udp build
# Compile un badvpn-udpgw STATIQUE (indépendant de la version de la
# distribution) et le dépose dans /root/ pour que tu l'uploades sur GitHub.
if [ "$1" = "build" ]; then
  banner; center " FABRICATION DU BINAIRE UDP " "${BOLD}${WHT}"; line
  printf "${CYN}➜${NC} Installation des outils de compilation…\n"
  apt-get update -y >/dev/null 2>&1
  apt-get install -y cmake make gcc build-essential curl >/dev/null 2>&1
  SRC=/tmp/badvpn-build; rm -rf "$SRC"; mkdir -p "$SRC"
  printf "${CYN}➜${NC} Téléchargement de la source officielle…\n"
  if ! curl -fsSL "https://github.com/ambrop72/badvpn/archive/refs/tags/1.999.130.tar.gz" -o "$SRC/b.tar.gz" 2>/dev/null; then
    err "Téléchargement impossible."; pause; exit 1
  fi
  tar xzf "$SRC/b.tar.gz" -C "$SRC" 2>/dev/null
  BD=$(find "$SRC" -maxdepth 1 -type d -name 'badvpn-*' | head -1)
  [ -z "$BD" ] && { err "Archive illisible."; pause; exit 1; }
  printf "${CYN}➜${NC} Compilation statique (2 à 4 minutes)…\n"
  mkdir -p "$SRC/out"; cd "$SRC/out" || exit 1
  cmake "$BD" -DCMAKE_BUILD_TYPE=Release \
    -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 \
    -DBUILDNOTHINGBYDEFAULT=1 -DBUILDUDPGW=1 \
    -DCMAKE_EXE_LINKER_FLAGS="-static" >/dev/null 2>&1
  make -j"$(nproc 2>/dev/null || echo 1)" >/dev/null 2>&1
  OUT=$(find "$SRC/out" -type f -name 'badvpn-udpgw' 2>/dev/null | head -1)
  # si le statique échoue, on retente en dynamique
  if [ -z "$OUT" ]; then
    printf "${YLW}!${NC} Statique impossible, compilation classique…\n"
    rm -rf "$SRC/out"; mkdir -p "$SRC/out"; cd "$SRC/out" || exit 1
    cmake "$BD" -DCMAKE_BUILD_TYPE=Release \
      -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 \
      -DBUILDNOTHINGBYDEFAULT=1 -DBUILDUDPGW=1 >/dev/null 2>&1
    make -j"$(nproc 2>/dev/null || echo 1)" >/dev/null 2>&1
    OUT=$(find "$SRC/out" -type f -name 'badvpn-udpgw' 2>/dev/null | head -1)
  fi
  cd / || true
  if [ -n "$OUT" ] && is_bin "$OUT"; then
    case "$(uname -m)" in
      aarch64|arm64) DEST=/root/badvpn-udpgw-arm64 ;;
      *)             DEST=/root/badvpn-udpgw ;;
    esac
    install -m755 "$OUT" "$DEST"
    rm -rf "$SRC"
    clear; banner; center " ✔  BINAIRE PRÊT " "${BOLD}${GRN}"; line
    ok "Fichier créé : ${WHT}$DEST${NC}"
    printf "   ${GRY}Taille : %s${NC}\n\n" "$(du -h "$DEST" | cut -f1)"
    printf "   ${WHT}À faire maintenant :${NC}\n"
    printf "   ${GRY}1. Récupère ce fichier (Termius → SFTP → /root/)${NC}\n"
    printf "   ${GRY}2. Uploade-le à la racine de ton dépôt GitHub${NC}\n"
    printf "   ${GRY}   sous le nom :${NC} ${WHT}%s${NC}\n" "$(basename "$DEST")"
    printf "   ${GRY}3. Ensuite l'UDP s'installera tout seul chez tous tes clients,${NC}\n"
    printf "   ${GRY}   exactement comme SlowDNS.${NC}\n"
  else
    rm -rf "$SRC"
    err "La compilation a échoué (RAM insuffisante ?)."
    printf "   ${GRY}Essaie sur un VPS avec au moins 1 Go de RAM.${NC}\n"
  fi
  pause; exit 0
fi

[ "$AUTO" = 1 ] || { banner; center " INSTALLATION UDP " "${BOLD}${WHT}"; line; }

# ---------- 1) badvpn-udpgw ---------------------------------
[ "$AUTO" = 1 ] || printf "${CYN}➜${NC} Installation de badvpn-udpgw…\n"
BADVPN=""
export DEBIAN_FRONTEND=noninteractive

# a) BINAIRE HÉBERGÉ DANS TON DÉPÔT — méthode principale, comme SlowDNS.
#    Même fichier pour tous tes clients : instantané et prévisible.
case "$(uname -m)" in
  aarch64|arm64) BSRC="badvpn-udpgw-arm64" ;;
  *)             BSRC="badvpn-udpgw" ;;
esac
curl -fsSL "$REPO_RAW/$BSRC" -o "$DIR/badvpn-udpgw" 2>/dev/null
if is_bin "$DIR/badvpn-udpgw"; then
  chmod +x "$DIR/badvpn-udpgw"
  # le binaire tourne-t-il vraiment ici ? (126/127 = incompatible ou lib manquante)
  "$DIR/badvpn-udpgw" --help >/dev/null 2>&1
  _rc=$?
  if [ "$_rc" -ne 126 ] && [ "$_rc" -ne 127 ]; then
    BADVPN="$DIR/badvpn-udpgw"
  fi
fi
[ -n "$BADVPN" ] || rm -f "$DIR/badvpn-udpgw"

# b) secours : paquet de la distribution (n'existe pas partout)
if [ -z "$BADVPN" ]; then
  command -v badvpn-udpgw >/dev/null 2>&1 || { apt-get update -y >/dev/null 2>&1; apt-get install -y badvpn >/dev/null 2>&1; }
  command -v badvpn-udpgw >/dev/null 2>&1 && BADVPN=$(command -v badvpn-udpgw)
fi

# c) DERNIER RECOURS : compilation depuis la source officielle.
#    C'est la méthode la plus fiable : elle fonctionne sur n'importe quel
#    VPS Debian/Ubuntu, en x86_64 comme en ARM, sans dépendre d'un dépôt.
if [ -z "$BADVPN" ]; then
  [ "$AUTO" = 1 ] || printf "${CYN}➜${NC} Compilation de badvpn-udpgw (2 à 4 minutes)…\n"
  apt-get install -y cmake make gcc build-essential >/dev/null 2>&1
  SRC=/tmp/badvpn-src
  rm -rf "$SRC"; mkdir -p "$SRC"
  if curl -fsSL "https://github.com/ambrop72/badvpn/archive/refs/tags/1.999.130.tar.gz" \
       -o "$SRC/badvpn.tar.gz" 2>/dev/null && tar xzf "$SRC/badvpn.tar.gz" -C "$SRC" 2>/dev/null; then
    BSRCDIR=$(find "$SRC" -maxdepth 1 -type d -name 'badvpn-*' | head -1)
    if [ -n "$BSRCDIR" ]; then
      mkdir -p "$SRC/build" && cd "$SRC/build" || true
      # les deux orthographes d'options selon les versions de badvpn
      cmake "$BSRCDIR" -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 \
        -DBUILDNOTHINGBYDEFAULT=1 -DBUILDUDPGW=1 >/dev/null 2>&1
      make -j"$(nproc 2>/dev/null || echo 1)" >/dev/null 2>&1
      COMPILED=$(find "$SRC/build" -type f -name 'badvpn-udpgw' 2>/dev/null | head -1)
      if [ -n "$COMPILED" ] && is_bin "$COMPILED"; then
        install -m755 "$COMPILED" /usr/local/bin/badvpn-udpgw 2>/dev/null
        BADVPN=/usr/local/bin/badvpn-udpgw
      fi
      cd / || true
    fi
  fi
  rm -rf "$SRC"
fi

UDPGW_OK=0
if [ -n "$BADVPN" ]; then
  for p in 7100 7200 7300; do
    cat > /etc/systemd/system/nvpanel-badvpn-$p.service <<EOF
[Unit]
Description=RHAFF SERVICE badvpn-udpgw $p
After=network.target
[Service]
ExecStart=$BADVPN --listen-addr 127.0.0.1:$p --max-clients 500 --max-connections-for-client 10
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
EOF
  done
  systemctl daemon-reload >/dev/null 2>&1
  for p in 7100 7200 7300; do
    systemctl enable --now nvpanel-badvpn-$p >/dev/null 2>&1
  done
  sleep 1
  for p in 7100 7200 7300; do
    systemctl is-active --quiet nvpanel-badvpn-$p && UDPGW_OK=$((UDPGW_OK+1))
  done
fi

# preuve réelle : le port 7300 écoute-t-il vraiment ?
LISTEN_OK=0
if command -v ss >/dev/null 2>&1; then
  ss -lnt 2>/dev/null | grep -q '127.0.0.1:7300' && LISTEN_OK=1
elif command -v netstat >/dev/null 2>&1; then
  netstat -lnt 2>/dev/null | grep -q '127.0.0.1:7300' && LISTEN_OK=1
fi

# ---------- 2) udp-custom (optionnel) -----------------------
[ "$AUTO" = 1 ] || printf "${CYN}➜${NC} udp-custom (optionnel)…\n"
UDPC_OK=0
curl -fsSL "$REPO_RAW/$UDPC_SRC" -o "$DIR/udp-custom" 2>/dev/null
if is_bin "$DIR/udp-custom"; then
  chmod +x "$DIR/udp-custom"
  [ -f "$DIR/config.json" ] || cat > "$DIR/config.json" <<'EOF'
{ "listen": ":36712", "stream_buffer": 33554432, "receive_buffer": 83886080, "auth": { "mode": "passwords" } }
EOF
  cat > /etc/systemd/system/nvpanel-udp-custom.service <<EOF
[Unit]
Description=RHAFF SERVICE udp-custom
After=network.target
[Service]
WorkingDirectory=$DIR
ExecStart=$DIR/udp-custom server -exclude 1-21,23-52,54-79
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload >/dev/null 2>&1
  systemctl enable --now nvpanel-udp-custom >/dev/null 2>&1
  sleep 1
  systemctl is-active --quiet nvpanel-udp-custom && UDPC_OK=1
else
  rm -f "$DIR/udp-custom"
fi

# ---------- 3) pare-feu : autoriser l'UDP -------------------
if command -v iptables >/dev/null 2>&1; then
  iptables -C INPUT -p udp --dport 36712 -j ACCEPT 2>/dev/null || \
    iptables -I INPUT -p udp --dport 36712 -j ACCEPT 2>/dev/null
fi
command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi active && \
  ufw allow 36712/udp >/dev/null 2>&1

# le compteur de conso doit connaître les nouveaux ports
[ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1

# ---------- 4) rapport honnête ------------------------------
if [ "$AUTO" = 1 ]; then
  [ "$UDPGW_OK" -gt 0 ] && printf "  ${GRN}✔${NC} UDP (UDPGW) actif.\n" || printf "  ${YLW}!${NC} UDP non activé.\n"
  exit 0
fi

clear; banner
if [ "$LISTEN_OK" = 1 ]; then
  center " ✔  UDP OPÉRATIONNEL " "${BOLD}${GRN}"; line
  ok "UDPGW écoute bien sur 127.0.0.1:7300 (services actifs : $UDPGW_OK/3)"
  printf "   ${GRY}Vérifié en direct : le port répond, la connexion UDP passera.${NC}\n\n"
  printf "   ${WHT}Côté application cliente :${NC}\n"
  printf "   ${GRY}• Active « UDPGW » (ou « Payload UDP »)${NC}\n"
  printf "   ${GRY}• Adresse à saisir :${NC} ${WHT}127.0.0.1:7300${NC}\n"
  printf "   ${GRY}• L'UDP passe DANS le tunnel SSH : il faut être connecté en SSH.${NC}\n"
elif [ "$UDPGW_OK" -gt 0 ]; then
  center " ⚠  UDP PARTIEL " "${BOLD}${YLW}"; line
  warn "Les services sont lancés mais le port 7300 ne répond pas encore."
  printf "   ${GRY}Attends quelques secondes puis relance ce menu pour revérifier.${NC}\n"
else
  center " ✘  UDP NON ACTIVÉ " "${BOLD}${RED}"; line
  err "badvpn-udpgw n'a pas pu être installé ni compilé."
  printf "   ${GRY}Causes possibles : pas assez de RAM pour compiler, ou pas d'accès${NC}\n"
  printf "   ${GRY}à GitHub depuis ce VPS.${NC}\n"
  printf "   ${GRY}Solution : dépose un binaire « badvpn-udpgw » (et « badvpn-udpgw-arm64 »${NC}\n"
  printf "   ${GRY}pour l'ARM) à la racine de ton dépôt GitHub, puis relance.${NC}\n"
fi
echo
if [ "$UDPC_OK" = 1 ]; then
  ok "udp-custom actif (port 36712)"
else
  printf "   ${GRY}udp-custom : non installé (binaire « %s » absent du dépôt).${NC}\n" "$UDPC_SRC"
  printf "   ${GRY}Ce module est facultatif : l'UDP fonctionne sans lui.${NC}\n"
fi
pause
