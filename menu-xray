#!/bin/bash
# ============================================================
#  nvpanel · gestion Xray   (menu-xray vmess|vless|trojan)
#  Interface — la logique est dans nvpanel-cli (partagée avec le bot)
# ============================================================
source /etc/nvpanel/lib/ui.sh
ui_enter; trap ui_leave EXIT
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
PROTO="$1"
case "$PROTO" in vmess|vless|trojan) ;; *) err "Protocole inconnu"; exit 1 ;; esac

case "$PROTO" in vmess) LPORT=8080 ;; vless) LPORT=8081 ;; trojan) LPORT=8082 ;; esac
header(){ banner; center " GESTION ${PROTO^^} (XRAY) " "${BOLD}${WHT}"; line; proto_dash "$PROTO" "port:$LPORT"; line; }

ensure_xray() {
  if [ ! -f /usr/local/etc/xray/config.json ] || ! command -v xray >/dev/null 2>&1; then
    warn "Xray n'est pas installé."
    ask " L'installer maintenant ? (o/n) : " r
    confirm "$r" && install-xray || return 1
  fi
}

add_client() {
  header; ask " Nom du client : " name
  [ -z "$name" ] && { err "Nom vide"; pause; return; }
  ask " Durée (jours) : " days
  out=$(nvpanel-cli xadd "$PROTO" "$name" "$days")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Client ${PROTO^^} créé"
    echo; printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else
    err "Échec : $(echo "$out" | head -1)"
  fi
  pause
}

list_clients() {
  header; printf " ${GRY}%-20s %s${NC}\n" "Nom" "Expire"; line
  nvpanel-cli xlist "$PROTO" | while IFS='|' ask "" n e; do printf " %-20s %s\n" "$n" "$e"; done
  pause
}

pick_client() {
  PICK=""
  mapfile -t _cl < <(nvpanel-cli xlist "$PROTO" | awk -F'|' 'NF{print $1"|"$2}')
  if [ "${#_cl[@]}" -eq 0 ]; then err "Aucun client ${PROTO^^}."; pause; return 1; fi
  echo; printf "   ${GRY}Clients ${PROTO^^} :${NC}\n"
  local i=1 row
  for row in "${_cl[@]}"; do
    printf "   ${WHT}%2d${NC}) %-18s ${GRY}exp %s${NC}\n" "$i" "${row%%|*}" "${row##*|}"
    i=$((i+1))
  done
  echo; ask "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_cl[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_cl[$((n-1))]%%|*}"; return 0
}

del_client() {
  header; pick_client || return; name="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$name"; ask "" c; confirm "$c" || { pause; return; }
  r=$(nvpanel-cli xdel "$PROTO" "$name")
  echo "$r" | grep -q '^OK' && ok "$name supprimé" || err "$r"; pause
}

renew_client() {
  header; pick_client || return; name="$PICK"
  ask " Ajouter (jours) : " days
  r=$(nvpanel-cli xrenew "$PROTO" "$name" "$days")
  echo "$r" | grep -q '^OK' && ok "Prolongé jusqu'au $(echo "$r"|awk '{print $3}')" || err "$r"; pause
}

view_client() {
  header; pick_client || return; name="$PICK"
  out=$(nvpanel-cli xinfo "$PROTO" "$name")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else err "Introuvable : $out"; fi
  pause
}

cleanup_menu() {
  while true; do
    header; center " 🧹  NETTOYAGE ${PROTO^^} " "${BOLD}${WHT}"; line
    local tot exp today c r out
    today=$(date +%F)
    tot=$(nvpanel-cli xlist "$PROTO" 2>/dev/null | grep -c '|')
    exp=$(nvpanel-cli xlist "$PROTO" 2>/dev/null | awk -F'|' -v d="$today" 'NF && $2!="" && $2<d {c++} END{print c+0}')
    printf "   ${GRY}Clients au total :${NC} ${WHT}%s${NC}    ${GRY}dont expirés :${NC} ${RED}%s${NC}\n\n" "$tot" "$exp"
    entry "1" "🧽" "Supprimer les clients expirés"
    entry "2" "💥" "Supprimer TOUS les clients"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) [ "$exp" -eq 0 ] && { warn "Aucun client expiré."; pause; continue; }
         printf "   ${YLW}Supprimer les %s client(s) expiré(s) ? (o/n) : ${NC}" "$exp"; ask "" r
         confirm "$r" || continue
         out=$(nvpanel-cli purge "$PROTO" expired)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      2) [ "$tot" -eq 0 ] && { warn "Aucun client."; pause; continue; }
         warn "Cela supprimera les $tot clients ${PROTO^^}. Action irréversible."
         printf "   ${RED}➤ Confirmer la suppression totale ? (o/n) : ${NC}"; ask "" r
         confirm "$r" || { warn "Annulé."; pause; continue; }
         out=$(nvpanel-cli purge "$PROTO" all)
         ok "$(echo "$out" | awk '{print $2+0}') client(s) supprimé(s)."; pause ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

uninstall_xray(){
  header; center " 🗑️  DÉSINSTALLER XRAY " "${BOLD}${RED}"; line
  warn "ATTENTION : le cœur Xray gère 4 protocoles à la fois."
  printf "   ${YLW}Vmess · Vless · Trojan · Shadowsocks seront TOUS supprimés,${NC}\n"
  printf "   ${YLW}avec l'ensemble de leurs clients.${NC}\n"
  printf "   ${GRY}SSH, SlowDNS, UDP, WireGuard, L2TP, PPTP et SSTP ne sont pas touchés.${NC}\n\n"
  printf "   ${RED}➤ Confirmer la désinstallation ? (o/n) : ${NC}"; ask "" r
  confirm "$r" || { warn "Annulé."; pause; return; }

  printf "\n${CYN}➜${NC} Arrêt et retrait de Xray…\n"
  systemctl disable --now xray >/dev/null 2>&1
  bash <(curl -sL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) remove --purge >/dev/null 2>&1
  rm -rf /usr/local/etc/xray /etc/nvpanel/xray

  printf "${CYN}➜${NC} Suppression des clients…\n"
  rm -f /etc/nvpanel/db/vmess /etc/nvpanel/db/vless /etc/nvpanel/db/trojan /etc/nvpanel/db/shadowsocks

  printf "${CYN}➜${NC} Retrait de la façade web…\n"
  rm -f /etc/nginx/conf.d/rhaff.conf /etc/nginx/nvpanel-ws.conf
  nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
  [ -x /usr/local/bin/nvpanel-conso ] && /usr/local/bin/nvpanel-conso setup >/dev/null 2>&1
  ok "Xray a été désinstallé (Vmess, Vless, Trojan, Shadowsocks)."
  pause
}

setup_menu(){
  while true; do
    header; center " ⚙️  INSTALLER / DÉSINSTALLER XRAY " "${BOLD}${WHT}"; line
    if systemctl is-active --quiet xray 2>/dev/null; then
      printf "   ${GRY}État actuel :${NC} ${GRN}installé et actif${NC}\n"
    else
      printf "   ${GRY}État actuel :${NC} ${RED}non installé${NC}\n"
    fi
    printf "   ${GRY}Concerne Vmess · Vless · Trojan · Shadowsocks${NC}\n\n"
    entry "1" "⬇️" "Installer / réinstaller"
    entry "2" "🗑️" "Désinstaller"
    entry "0" "⬅️" "Retour"
    line
    ask "$(printf " ${WHT}➤ Choix :${NC} ")" c
    case "$c" in
      1) install-xray ;;
      2) uninstall_xray ;;
      0) break ;;
      *) warn "Invalide"; sleep 1 ;;
    esac
  done
}

ensure_xray || exit 0
while true; do
  header
  entry "1" "➕" "Ajouter un client"
  entry "2" "📋" "Lister les clients"
  entry "3" "🔍" "Revoir un client (infos + lien)"
  entry "4" "♻️" "Prolonger un client"
  entry "5" "🗑️" "Supprimer un client"
  entry "6" "🧹" "Nettoyage (expirés / tout supprimer)"
  entry "7" "⚙️" "Installer / désinstaller Xray"
  entry "0" "⬅️" "Retour"
  line
  ask "$(printf " ${WHT}Choix :${NC} ")" o
  case "$o" in
    1) add_client ;; 2) list_clients ;; 3) view_client ;;
    4) renew_client ;; 5) del_client ;; 6) cleanup_menu ;; 7) setup_menu ;;
    0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
