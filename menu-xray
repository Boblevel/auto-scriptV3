#!/bin/bash
# ============================================================
#  nvpanel · gestion Xray   (menu-xray vmess|vless|trojan)
#  Interface — la logique est dans nvpanel-cli (partagée avec le bot)
# ============================================================
source /etc/nvpanel/lib/ui.sh
[ "$EUID" -ne 0 ] && { err "Lance en root."; exit 1; }
PROTO="$1"
case "$PROTO" in vmess|vless|trojan) ;; *) err "Protocole inconnu"; exit 1 ;; esac

case "$PROTO" in vmess) LPORT=8080 ;; vless) LPORT=8081 ;; trojan) LPORT=8082 ;; esac
header(){ banner; center " GESTION ${PROTO^^} (XRAY) " "${BOLD}${WHT}"; line; proto_dash "$PROTO" "port:$LPORT"; line; }

ensure_xray() {
  if [ ! -f /usr/local/etc/xray/config.json ] || ! command -v xray >/dev/null 2>&1; then
    warn "Xray n'est pas installé."
    read -rp " L'installer maintenant ? (o/n) : " r
    confirm "$r" && install-xray || return 1
  fi
}

add_client() {
  header; read -rp " Nom du client : " name
  [ -z "$name" ] && { err "Nom vide"; pause; return; }
  read -rp " Durée (jours) : " days
  out=$(nvpanel-cli xadd "$PROTO" "$name" "$days")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then
    ok "Client ${PROTO^^} créé"
    echo; printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else
    err "Échec : $(echo "$out" | head -1)"
  fi
  pause
}

list_clients() {
  header; printf " ${GRY}%-20s %s${NC}\n" "Nom" "Expire"; line
  nvpanel-cli xlist "$PROTO" | while IFS='|' read -r n e; do printf " %-20s %s\n" "$n" "$e"; done
  pause
}

pick_client() {
  PICK=""
  mapfile -t _cl < <(nvpanel-cli xlist "$PROTO" | awk -F'|' 'NF{print $1"|"$2}')
  if [ "${#_cl[@]}" -eq 0 ]; then err "Aucun client ${PROTO^^}."; pause; return 1; fi
  echo; printf "   ${GRY}Clients ${PROTO^^} :${NC}\n"
  local i=1 row
  for row in "${_cl[@]}"; do
    printf "   ${WHT}%2d${NC}) %-18s ${GRY}exp %s${NC}\n" "$i" "${row%%|*}" "${row##*|}"
    i=$((i+1))
  done
  echo; read -rp "   ➤ Numéro (0 = annuler) : " n
  [[ "$n" =~ ^[0-9]+$ ]] || { err "Invalide"; pause; return 1; }
  [ "$n" -eq 0 ] && return 1
  [ "$n" -ge 1 ] && [ "$n" -le "${#_cl[@]}" ] || { err "Hors liste"; pause; return 1; }
  PICK="${_cl[$((n-1))]%%|*}"; return 0
}

del_client() {
  header; pick_client || return; name="$PICK"
  printf "   ${YLW}Supprimer '%s' ? (o/n) : ${NC}" "$name"; read -r c; confirm "$c" || { pause; return; }
  r=$(nvpanel-cli xdel "$PROTO" "$name")
  echo "$r" | grep -q '^OK' && ok "$name supprimé" || err "$r"; pause
}

renew_client() {
  header; pick_client || return; name="$PICK"
  read -rp " Ajouter (jours) : " days
  r=$(nvpanel-cli xrenew "$PROTO" "$name" "$days")
  echo "$r" | grep -q '^OK' && ok "Prolongé jusqu'au $(echo "$r"|awk '{print $3}')" || err "$r"; pause
}

view_client() {
  header; pick_client || return; name="$PICK"
  out=$(nvpanel-cli xinfo "$PROTO" "$name")
  clear; header
  if echo "$out" | head -1 | grep -q '^OK'; then printf "${GRN}"; echo "$out" | tail -n +2; printf "${NC}"
  else err "Introuvable : $out"; fi
  pause
}

ensure_xray || exit 0
while true; do
  header
  entry "1" "➕" "Ajouter un client"
  entry "2" "📋" "Lister les clients"
  entry "3" "🔍" "Revoir un client (infos + lien)"
  entry "4" "♻️" "Prolonger un client"
  entry "5" "🗑️" "Supprimer un client"
  entry "0" "⬅️" "Retour"
  line
  read -rp "$(printf " ${WHT}Choix :${NC} ")" o
  case "$o" in
    1) add_client ;; 2) list_clients ;; 3) view_client ;;
    4) renew_client ;; 5) del_client ;; 0) break ;; *) warn "Invalide"; sleep 1 ;;
  esac
done
